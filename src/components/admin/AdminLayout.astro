---
/**
 * AdminLayout.astro
 * Protected admin layout with sidebar navigation for the admin dashboard.
 * 
 * @props title - Page title shown in browser tab and header
 * @props description - Optional page description
 * @props activeNav - Currently active navigation item for highlighting
 */
import Layout from '../../layouts/Layout.astro';
import { requireAdmin } from '../../lib/server/auth';

export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

// Verify admin access - must be first to handle redirects
const authResult = await requireAdmin(Astro);
if (authResult instanceof Response) return authResult;

const { title, description, activeNav = '' } = Astro.props;

// Navigation items for admin sidebar
const navItems = [
  { href: '/admin', label: 'Dashboard', icon: 'dashboard', id: 'dashboard' },
  { href: '/admin/users', label: 'Users', icon: 'users', id: 'users' },
  { href: '/admin/blog', label: 'Blog', icon: 'blog', id: 'blog' },
  { href: '/admin/forum-categories', label: 'Forum', icon: 'forum', id: 'forum' },
  { href: '/admin/snippets', label: 'Snippets', icon: 'snippets', id: 'snippets' },
  { href: '/admin/subscriptions', label: 'Subscriptions', icon: 'subscriptions', id: 'subscriptions' },
  { href: '/admin/payments', label: 'Payments', icon: 'payments', id: 'payments' },
  { href: '/admin/categories', label: 'Forum Categories', icon: 'categories', id: 'categories' },
  { href: '/admin/newsletter', label: 'Newsletter', icon: 'newsletter', id: 'newsletter' },
];

// Icons for navigation
const icons: Record<string, string> = {
  dashboard: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  users: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  blog: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0012.586 3H12"/></svg>`,
  forum: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>`,
  snippets: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
  subscriptions: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
  payments: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  newsletter: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
};

const currentPath = Astro.url.pathname;
---

<Layout title={`${title} - Admin Dashboard`} description={description}>
  <div class="drawer lg:drawer-open overflow-x-hidden">
    <input id="admin-drawer" type="checkbox" class="drawer-toggle" />
    
    <div class="drawer-content flex flex-col bg-base-200 overflow-x-hidden">
      <!-- Mobile Header -->
      <div class="lg:hidden sticky top-0 z-30 flex h-16 w-full justify-between items-center bg-base-100 border-b border-base-300 px-4 shadow-sm">
        <div class="flex items-center gap-3">
          <label for="admin-drawer" class="btn btn-square btn-ghost">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </label>
          <span class="font-bold text-lg">Admin</span>
        </div>
        <a href="/dashboard" class="btn btn-ghost btn-sm">Exit Admin</a>
      </div>

      <!-- Main Content -->
      <main class="flex-1">
        <div class="p-4 lg:p-6">
          <!-- Page Header -->
          <div class="mb-4">
            <h1 class="text-2xl lg:text-3xl font-bold">{title}</h1>
            {description && (
              <p class="text-base-content/70 mt-1">{description}</p>
            )}
          </div>

          <!-- Page Content -->
          <slot />
        </div>
      </main>
    </div>

    <div class="drawer-side z-40 overflow-x-hidden">
      <label for="admin-drawer" aria-label="close sidebar" class="drawer-overlay lg:hidden"></label>
      
      <aside
        id="admin-sidebar"
        class="group bg-base-100 min-h-full w-64 flex flex-col border-r border-base-300 transition-all duration-300 overflow-x-hidden data-[collapsed=true]:w-18 lg:w-64"
        data-collapsed="false"
      >
        <!-- Sidebar Header -->
        <div class="p-4 border-b border-base-300 flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0 sidebar-content">
            <div class="w-10 h-10 bg-primary rounded-lg flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-primary-content" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <h1 class="font-bold text-lg">Admin Panel</h1>
              <p class="text-xs text-base-content/60">Management Dashboard</p>
            </div>
          </div>
          <button 
            id="sidebar-toggle" 
            class="btn btn-ghost btn-sm btn-square hidden lg:flex shrink-0"
            aria-label="Toggle sidebar"
          >
            <svg class="w-5 h-5 sidebar-icon-expanded" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
            </svg>
            <svg class="w-5 h-5 sidebar-icon-collapsed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
            </svg>
          </button>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-4 overflow-y-auto overflow-x-hidden">
          <ul class="menu menu-lg gap-1 w-full">
            {navItems.map((item) => {
              const isActive = activeNav === item.id || 
                (activeNav === '' && item.href === '/admin' && currentPath === '/admin') ||
                (item.href !== '/admin' && currentPath.startsWith(item.href));
              return (
                <li class="w-full">
                  <a 
                    href={item.href} 
                    class:list={['flex items-center gap-3 w-full rounded-lg px-3 py-2 group-data-[collapsed=true]:justify-center group-data-[collapsed=true]:gap-0 group-data-[collapsed=true]:px-3', { 'active': isActive }]}
                  >
                    <span class="shrink-0" aria-hidden="true"><Fragment set:html={icons[item.icon]} /></span>
                    <span class="sidebar-content">{item.label}</span>
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>

        <!-- Sidebar Footer -->
        <div class="p-4 border-t border-base-300">
          <a href="/dashboard" class="btn btn-ghost btn-sm w-full justify-start gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
            </svg>
            <span class="sidebar-content">Exit Admin</span>
          </a>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  function initSidebar() {
    const sidebar = document.getElementById('admin-sidebar');
    const toggleBtn = document.getElementById('sidebar-toggle');
    const drawer = document.getElementById('admin-drawer') as HTMLInputElement;
    const expandedIcon = sidebar?.querySelector('.sidebar-icon-expanded');
    const collapsedIcon = sidebar?.querySelector('.sidebar-icon-collapsed');

    const applyState = (collapsed: boolean) => {
      if (!sidebar) return;
      sidebar.setAttribute('data-collapsed', String(collapsed));
      expandedIcon?.classList.toggle('hidden', collapsed);
      collapsedIcon?.classList.toggle('hidden', !collapsed);
      sidebar.querySelectorAll('.sidebar-content').forEach((el) => {
        (el as HTMLElement).classList.toggle('hidden', collapsed);
      });
    };

    // Load saved state
    const isCollapsed = localStorage.getItem('admin-sidebar-collapsed') === 'true';
    applyState(isCollapsed);
    
    // Toggle sidebar
    toggleBtn?.addEventListener('click', () => {
      const next = sidebar?.getAttribute('data-collapsed') === 'true' ? false : true;
      applyState(next);
      localStorage.setItem('admin-sidebar-collapsed', String(next));
    });
    
    // Close drawer on navigation
    if (drawer) {
      drawer.checked = false;
    }
  }
  
  // Initialize on page load
  document.addEventListener('astro:page-load', initSidebar);
  initSidebar();
</script>
