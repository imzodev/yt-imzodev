---
/**
 * DataTable.astro
 * Reusable sortable and filterable data table component.
 * 
 * @props columns - Array of column definitions
 * @props data - Array of row data objects
 * @props searchable - Enable search functionality (default: true)
 * @props searchPlaceholder - Placeholder text for search input
 * @props emptyMessage - Message to show when no data
 * @props striped - Apply striped rows (default: true)
 * @props hoverable - Enable row hover effect (default: true)
 * @props pageSize - Number of rows per page (default: 10, 0 for no pagination)
 */

export interface Column {
  key: string;
  label: string;
  sortable?: boolean;
  align?: 'left' | 'center' | 'right';
  width?: string;
  render?: (value: unknown, row: Record<string, unknown>) => string;
}

export interface Props {
  columns: Column[];
  data: Record<string, unknown>[];
  searchable?: boolean;
  searchPlaceholder?: string;
  emptyMessage?: string;
  striped?: boolean;
  hoverable?: boolean;
  pageSize?: number;
  id?: string;
}

const {
  columns,
  data,
  searchable = true,
  searchPlaceholder = 'Search...',
  emptyMessage = 'No data available',
  striped = true,
  hoverable = true,
  pageSize = 10,
  id = `data-table-${Math.random().toString(36).slice(2, 9)}`
} = Astro.props;

// Generate table ID for client-side functionality
const tableId = id;
---

<div class="bg-base-100 shadow rounded-lg overflow-hidden" id={tableId}>
  <!-- Search Bar -->
  {searchable && (
    <div class="p-4 border-b border-base-300">
      <div class="relative">
        <input 
          type="text" 
          placeholder={searchPlaceholder}
          class="input input-bordered w-full pl-10"
          data-table-search={tableId}
        />
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-base-content/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>
  )}

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class:list={['table w-full', { 'table-zebra': striped }]}>
      <thead>
        <tr>
          {columns.map((column) => (
            <th 
              class:list={[
                column.align === 'center' ? 'text-center' : column.align === 'right' ? 'text-right' : 'text-left',
                column.sortable && 'cursor-pointer select-none hover:bg-base-200'
              ]}
              style={column.width ? `width: ${column.width}` : undefined}
              data-sort-key={column.sortable ? column.key : undefined}
              data-table-header={tableId}
            >
              <div class="flex items-center gap-2">
                <span>{column.label}</span>
                {column.sortable && (
                  <span class="text-base-content/40">
                    <svg class="w-4 h-4 sort-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"/>
                    </svg>
                  </span>
                )}
              </div>
            </th>
          ))}
        </tr>
      </thead>
      <tbody data-table-body={tableId}>
        {data.length === 0 ? (
          <tr>
            <td colspan={columns.length} class="text-center py-8 text-base-content/60">
              {emptyMessage}
            </td>
          </tr>
        ) : (
          data.map((row, index) => (
            <tr class:list={[{ 'hover': hoverable }]} data-row-index={index}>
              {columns.map((column) => {
                const value = row[column.key];
                const renderedValue = column.render 
                  ? column.render(value, row)
                  : String(value ?? '-');
                return (
                  <td 
                    class:list={[
                      column.align === 'center' ? 'text-center' : column.align === 'right' ? 'text-right' : 'text-left'
                    ]}
                  >
                    <Fragment set:html={renderedValue} />
                  </td>
                );
              })}
            </tr>
          ))
        )}
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  {pageSize > 0 && data.length > pageSize && (
    <div class="p-4 border-t border-base-300 flex items-center justify-between">
      <div class="text-sm text-base-content/60">
        Showing <span data-table-showing={tableId}>1-{pageSize}</span> of <span data-table-total={tableId}>{data.length}</span> results
      </div>
      <div class="join">
        <button class="join-item btn btn-sm" data-table-prev={tableId} disabled>«</button>
        <button class="join-item btn btn-sm">Page <span data-table-page={tableId}>1</span></button>
        <button class="join-item btn btn-sm" data-table-next={tableId}>»</button>
      </div>
    </div>
  )}
</div>

<script define:vars={{ tableId, pageSize, data }}>
  // Client-side search and sort functionality
  const table = document.getElementById(tableId);
  if (table) {
    const searchInput = table.querySelector(`[data-table-search="${tableId}"]`);
    const tbody = table.querySelector(`[data-table-body="${tableId}"]`);
    const headers = table.querySelectorAll(`[data-table-header="${tableId}"]`);
    
    let currentData = [...data];
    let sortKey = null;
    let sortDirection = 'asc';
    let currentPage = 1;
    
    // Search functionality
    searchInput?.addEventListener('input', (e) => {
      const query = e.target.value.toLowerCase();
      currentData = data.filter(row => 
        Object.values(row).some(val => 
          String(val).toLowerCase().includes(query)
        )
      );
      currentPage = 1;
      renderTable();
    });
    
    // Sort functionality
    headers.forEach(header => {
      header.addEventListener('click', () => {
        const key = header.dataset.sortKey;
        if (!key) return;
        
        if (sortKey === key) {
          sortDirection = sortDirection === 'asc' ? 'desc' : 'asc';
        } else {
          sortKey = key;
          sortDirection = 'asc';
        }
        
        currentData.sort((a, b) => {
          const aVal = a[key];
          const bVal = b[key];
          
          if (aVal === bVal) return 0;
          if (aVal === null || aVal === undefined) return 1;
          if (bVal === null || bVal === undefined) return -1;
          
          const comparison = aVal < bVal ? -1 : 1;
          return sortDirection === 'asc' ? comparison : -comparison;
        });
        
        renderTable();
      });
    });
    
    function renderTable() {
      // This is a placeholder - actual re-rendering would need more complex logic
      // For server-side rendered tables, this would typically trigger a re-fetch
    }
  }
</script>
