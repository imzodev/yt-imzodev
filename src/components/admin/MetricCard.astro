---
/**
 * MetricCard.astro
 * Reusable component for displaying a single metric with optional trend indicator.
 * 
 * @props label - The metric label/name
 * @props value - The metric value to display
 * @props trend - Optional trend direction ('up', 'down', 'neutral')
 * @props trendValue - Optional trend value (e.g., "+5%", "-2%")
 * @props icon - Optional icon type ('currency', 'users', 'percent', 'number')
 * @props variant - Color variant ('default', 'success', 'warning', 'error', 'info')
 * @props size - Card size ('sm', 'md', 'lg')
 */

export interface Props {
  label: string;
  value: string | number;
  trend?: 'up' | 'down' | 'neutral';
  trendValue?: string;
  icon?: 'currency' | 'users' | 'percent' | 'number' | 'chart' | 'alert';
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info';
  size?: 'sm' | 'md' | 'lg';
}

const { 
  label, 
  value, 
  trend, 
  trendValue,
  icon,
  variant = 'default',
  size = 'md'
} = Astro.props;

// Size classes
const sizeClasses = {
  sm: 'p-4',
  md: 'p-6',
  lg: 'p-8'
};

const valueSizeClasses = {
  sm: 'text-xl',
  md: 'text-2xl',
  lg: 'text-3xl'
};

const labelSizeClasses = {
  sm: 'text-xs',
  md: 'text-sm',
  lg: 'text-base'
};

// Variant classes for the value
const variantClasses = {
  default: 'text-base-content',
  success: 'text-success',
  warning: 'text-warning',
  error: 'text-error',
  info: 'text-info'
};

// Trend classes
const trendClasses = {
  up: 'text-success',
  down: 'text-error',
  neutral: 'text-base-content/60'
};

const trendIcons = {
  up: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>`,
  down: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>`,
  neutral: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>`
};

// Icon SVGs
const iconSvgs = {
  currency: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
  users: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
  percent: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  number: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"/></svg>`,
  chart: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
  alert: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>`
};
---

<div class={`bg-base-100 shadow rounded-lg ${sizeClasses[size]}`}>
  <div class="flex items-start justify-between">
    <div class="flex-1">
      <p class:list={[`${labelSizeClasses[size]} text-base-content/70 mb-1`]}>{label}</p>
      <p class:list={[`${valueSizeClasses[size]} font-bold`, variantClasses[variant]]}>
        {value}
      </p>
      {(trend || trendValue) && (
        <div class:list={['flex items-center gap-1 mt-2', trendClasses[trend || 'neutral']]}>
          {trend && <Fragment set:html={trendIcons[trend]} />}
          {trendValue && <span class="text-sm font-medium">{trendValue}</span>}
        </div>
      )}
    </div>
    {icon && (
      <div class:list={['p-2 rounded-lg bg-base-200', variantClasses[variant]]}>
        <Fragment set:html={iconSvgs[icon]} />
      </div>
    )}
  </div>
</div>
