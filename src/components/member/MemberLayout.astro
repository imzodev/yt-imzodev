---
/**
 * MemberLayout.astro
 * Protected member layout with sidebar navigation for authenticated users.
 * 
 * @props title - Page title shown in browser tab and header
 * @props description - Optional page description
 * @props activeNav - Currently active navigation item for highlighting
 */
import Layout from '../../layouts/Layout.astro';
import { getSession } from '../../lib/server/auth';
import { getUnreadNotificationCount, getViewerBySupabaseId } from '../../lib/server/forum';

export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

// Check authentication - redirect to login if not authenticated
const authResult = await getSession(Astro, { requireAuth: true });
if (authResult instanceof Response) return authResult;
const { user } = authResult;

// Get user profile data
const viewer = await getViewerBySupabaseId(user!.id);
const unreadNotifications = viewer ? await getUnreadNotificationCount(viewer.id) : 0;

const { title, description, activeNav = '' } = Astro.props;

// Navigation items for member sidebar
const navItems = [
  { href: '/dashboard', label: 'Dashboard', icon: 'dashboard', id: 'dashboard' },
  { href: '/forum', label: 'Forum', icon: 'forum', id: 'forum', badge: unreadNotifications },
  { href: '/videos', label: 'Videos', icon: 'videos', id: 'videos' },
  { href: '/blog', label: 'Blog', icon: 'blog', id: 'blog' },
  { href: '/lab', label: 'Lab Tools', icon: 'lab', id: 'lab' },
  { href: '/profile', label: 'Profile', icon: 'profile', id: 'profile' },
];

// Icons for navigation
const icons: Record<string, string> = {
  dashboard: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  forum: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/></svg>`,
  videos: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`,
  blog: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>`,
  lab: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>`,
  profile: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
};

const currentPath = Astro.url.pathname;

// Get tier badge color
const tierBadgeClass = viewer?.subscriptionTier === 'premium' ? 'badge-warning' : 'badge-ghost';
---

<Layout title={`${title} - YouTube Community Portal`} description={description}>
  <div class="drawer lg:drawer-open overflow-x-hidden">
    <input id="member-drawer" type="checkbox" class="drawer-toggle" />
    
    <div class="drawer-content flex flex-col bg-base-200 overflow-x-hidden">
      <!-- Mobile Header -->
      <div class="lg:hidden sticky top-0 z-30 flex h-16 w-full justify-between items-center bg-base-100 border-b border-base-300 px-4 shadow-sm">
        <div class="flex items-center gap-3">
          <label for="member-drawer" class="btn btn-square btn-ghost">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </label>
          <span class="font-bold text-lg">Portal</span>
        </div>
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="btn btn-ghost btn-sm">Sign Out</button>
        </form>
      </div>

      <!-- Main Content -->
      <main class="flex-1">
        <div class="p-4 lg:p-6">
          <!-- Page Header -->
          <div class="mb-4">
            <h1 class="text-2xl lg:text-3xl font-bold">{title}</h1>
            {description && (
              <p class="text-base-content/70 mt-1">{description}</p>
            )}
          </div>

          <!-- Page Content -->
          <slot />
        </div>
      </main>
    </div>

    <div class="drawer-side z-40 overflow-x-hidden">
      <label for="member-drawer" aria-label="close sidebar" class="drawer-overlay lg:hidden"></label>
      
      <aside
        id="member-sidebar"
        class="group bg-base-100 min-h-full w-64 flex flex-col border-r border-base-300 transition-all duration-300 overflow-x-hidden data-[collapsed=true]:w-18 lg:w-64"
        data-collapsed="false"
      >
        <!-- Sidebar Header -->
        <div class="p-4 border-b border-base-300 flex items-center justify-between">
          <div class="flex items-center gap-3 min-w-0 sidebar-content">
            <div class="avatar placeholder shrink-0">
              <div class="bg-primary text-primary-content rounded-full w-10">
                <span class="text-lg">{viewer?.name?.charAt(0) || viewer?.username?.charAt(0) || viewer?.email?.charAt(0) || 'U'}</span>
              </div>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-sm truncate">{viewer?.name || viewer?.username || 'Member'}</p>
              <span class={`badge badge-xs ${tierBadgeClass}`}>
                {viewer?.subscriptionTier || 'free'}
              </span>
            </div>
          </div>
          <button 
            id="sidebar-toggle" 
            class="btn btn-ghost btn-sm btn-square hidden lg:flex shrink-0"
            aria-label="Toggle sidebar"
          >
            <svg class="w-5 h-5 sidebar-icon-expanded" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
            </svg>
            <svg class="w-5 h-5 sidebar-icon-collapsed hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"/>
            </svg>
          </button>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-4 overflow-y-auto overflow-x-hidden">
          <ul class="menu menu-lg gap-1 w-full">
            {navItems.map((item) => {
              const isActive = activeNav === item.id || 
                (activeNav === '' && item.href === '/dashboard' && currentPath === '/dashboard') ||
                (item.href !== '/dashboard' && currentPath.startsWith(item.href));
              return (
                <li class="w-full">
                  <a 
                    href={item.href} 
                    class:list={['flex items-center gap-3 w-full rounded-lg px-3 py-2 group-data-[collapsed=true]:justify-center group-data-[collapsed=true]:gap-0 group-data-[collapsed=true]:px-3', { 'active': isActive }]}
                  >
                    <span class="shrink-0" aria-hidden="true"><Fragment set:html={icons[item.icon]} /></span>
                    <span class="flex-1 sidebar-content">{item.label}</span>
                    {item.badge && item.badge > 0 && (
                      <span class="badge badge-sm badge-primary sidebar-content">{item.badge}</span>
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>

        <!-- Sidebar Footer -->
        <div class="p-4 border-t border-base-300">
          <form method="POST" action="/api/auth/logout" class="w-full">
            <button type="submit" class="btn btn-ghost btn-sm w-full justify-start gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
              </svg>
              <span class="sidebar-content">Sign Out</span>
            </button>
          </form>
        </div>
      </aside>
    </div>
  </div>
</Layout>

<script>
  function initSidebar() {
    const sidebar = document.getElementById('member-sidebar');
    const toggleBtn = document.getElementById('sidebar-toggle');
    const drawer = document.getElementById('member-drawer') as HTMLInputElement;
    const expandedIcon = sidebar?.querySelector('.sidebar-icon-expanded');
    const collapsedIcon = sidebar?.querySelector('.sidebar-icon-collapsed');

    const applyState = (collapsed: boolean) => {
      if (!sidebar) return;
      sidebar.setAttribute('data-collapsed', String(collapsed));
      expandedIcon?.classList.toggle('hidden', collapsed);
      collapsedIcon?.classList.toggle('hidden', !collapsed);
      sidebar.querySelectorAll('.sidebar-content').forEach((el) => {
        (el as HTMLElement).classList.toggle('hidden', collapsed);
      });
    };

    // Load saved state
    const isCollapsed = localStorage.getItem('member-sidebar-collapsed') === 'true';
    applyState(isCollapsed);
    
    // Toggle sidebar
    toggleBtn?.addEventListener('click', () => {
      const next = sidebar?.getAttribute('data-collapsed') === 'true' ? false : true;
      applyState(next);
      localStorage.setItem('member-sidebar-collapsed', String(next));
    });
    
    // Close drawer on navigation
    if (drawer) {
      drawer.checked = false;
    }
  }
  
  // Initialize on page load
  document.addEventListener('astro:page-load', initSidebar);
  initSidebar();
</script>
