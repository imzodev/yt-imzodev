---
export interface Props {
  snippet: {
    id: number;
    title: string;
    description: string;
    language: string;
    type: string;
    created_at: string;
    views: number;
    likes: number;
    category?: {
      name: string;
      slug: string;
    };
    author?: {
      name: string;
      avatar: string;
    };
  };
}

const { snippet } = Astro.props;

const languageColors: Record<string, string> = {
  javascript: 'bg-yellow-400 text-black',
  typescript: 'bg-blue-500 text-white',
  python: 'bg-blue-400 text-white',
  css: 'bg-pink-500 text-white',
  html: 'bg-orange-500 text-white',
  bash: 'bg-gray-800 text-white',
};

const badgeClass = languageColors[snippet.language] || 'bg-base-300 text-base-content';
---

<a href={`/snippets/${snippet.id}`} class="card bg-base-100 shadow-sm border border-base-200 hover:shadow-md transition-shadow duration-200">
  <div class="card-body p-5">
    <div class="flex justify-between items-start mb-2">
      <div class="flex gap-2">
        <span class={`badge border-none ${badgeClass}`}>{snippet.language}</span>
        {snippet.category && (
          <span class="badge badge-outline">{snippet.category.name}</span>
        )}
      </div>
      <span class="text-xs text-base-content/50 uppercase tracking-wider font-semibold">{snippet.type}</span>
    </div>
    
    <h2 class="card-title text-lg mb-1">{snippet.title}</h2>
    <p class="text-sm text-base-content/70 line-clamp-2 mb-4">{snippet.description}</p>
    
    <div class="flex items-center justify-between mt-auto pt-4 border-t border-base-200">
      <div class="flex items-center space-x-2">
        {snippet.author?.avatar ? (
          <div class="avatar">
            <div class="w-6 rounded-full">
              <img src={snippet.author.avatar} alt={snippet.author.name} />
            </div>
          </div>
        ) : (
          <div class="avatar placeholder">
            <div class="bg-neutral text-neutral-content rounded-full w-6">
              <span class="text-[10px]">{snippet.author?.name?.charAt(0) || '?'}</span>
            </div>
          </div>
        )}
        <span class="text-xs text-base-content/70 truncate max-w-[100px]">
          {snippet.author?.name || 'Anonymous'}
        </span>
      </div>
      
      <div class="flex items-center space-x-3 text-xs text-base-content/50">
        <span class="flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
          </svg>
          {snippet.views || 0}
        </span>
        <span class="flex items-center">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          {snippet.likes || 0}
        </span>
      </div>
    </div>
  </div>
</a>
