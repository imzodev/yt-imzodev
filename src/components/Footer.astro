---
/**
 * Footer Component
 * Site-wide footer with navigation links, social links, and copyright.
 * Uses DaisyUI theming and is fully responsive.
 */
const currentYear = new Date().getFullYear();
---

<footer class="bg-base-200 border-t border-base-300 mt-auto">
  <div class="container mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Column 1: Brand -->
      <div class="space-y-4">
        <a href="/" class="flex items-center gap-2">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <span class="text-white font-bold text-sm">IZ</span>
          </div>
          <span class="text-base-content font-bold text-lg">imzodev</span>
        </a>
        <p class="text-base-content/70 text-sm">
          AI & Software Development
        </p>
        <p class="text-base-content/60 text-sm">
          Tutorials, code snippets, and insights on modern software development and AI.
        </p>
      </div>

      <!-- Column 2: Content Links -->
      <div>
        <h3 class="font-semibold text-base-content mb-4">Content</h3>
        <ul class="space-y-2">
          <li>
            <a href="/videos" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Videos
            </a>
          </li>
          <li>
            <a href="/blog" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Blog
            </a>
          </li>
          <li>
            <a href="/snippets" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Snippets
            </a>
          </li>
          <li>
            <a href="/lab" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Lab Tools
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 3: Community -->
      <div>
        <h3 class="font-semibold text-base-content mb-4">Community</h3>
        <ul class="space-y-2">
          <li>
            <a href="/forum" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Forum
            </a>
          </li>
          <li>
            <a href="/newsletter" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Newsletter
            </a>
          </li>
          <li>
            <a href="/pricing" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Pricing
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 4: Legal & Social -->
      <div>
        <h3 class="font-semibold text-base-content mb-4">Legal & Social</h3>
        <ul class="space-y-2">
          <li>
            <a href="/privacy" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/terms" class="text-base-content/70 hover:text-primary transition-colors text-sm">
              Terms of Service
            </a>
          </li>
          <li>
            <a href="https://youtube.com/@imzodev" target="_blank" rel="noopener noreferrer" class="text-base-content/70 hover:text-primary transition-colors text-sm inline-flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              YouTube
            </a>
          </li>
          <li>
            <a href="https://github.com/imzodev" target="_blank" rel="noopener noreferrer" class="text-base-content/70 hover:text-primary transition-colors text-sm inline-flex items-center gap-1">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="divider"></div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-base-content/50">
        &copy; {currentYear} imzodev. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <span class="text-xs text-base-content/40">
          Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">Astro</a>
        </span>
      </div>
    </div>
  </div>
</footer>
