---
export interface Props {
  accessLevel?: 'public' | 'member' | 'premium';
  hasAccess: boolean;
  isAuthenticated: boolean;
  isPremium: boolean;
  contentType?: 'video' | 'blog' | 'snippet' | 'content';
}

const { 
  hasAccess, 
  isAuthenticated, 
  isPremium: _isPremium, 
  contentType = 'content' 
} = Astro.props;

if (hasAccess) {
  return;
}

const contentTypeLabel = contentType === 'video' ? 'video' : 
                         contentType === 'blog' ? 'blog post' : 
                         contentType === 'snippet' ? 'code snippet' : 'content';
---

<div class="not-prose">
  <div class="card bg-gradient-to-br from-primary/10 via-base-100 to-secondary/10 border-2 border-primary/20 shadow-xl">
    <div class="card-body text-center py-12 px-6">
      <!-- Lock Icon -->
      <div class="flex justify-center mb-4">
        <div class="w-20 h-20 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="w-10 h-10 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
      </div>
      
      <h3 class="text-2xl font-bold text-base-content mb-2">
        {isAuthenticated ? 'Upgrade to Premium' : 'Premium Content'}
      </h3>
      
      <p class="text-base-content/70 mb-6 max-w-md mx-auto">
        {isAuthenticated 
          ? `This ${contentTypeLabel} is exclusive to Premium members. Upgrade your account to unlock full access.`
          : `This ${contentTypeLabel} requires a Premium subscription. Sign in or create an account to get started.`
        }
      </p>
      
      <!-- Premium Benefits -->
      <div class="flex flex-wrap justify-center gap-3 mb-8">
        <span class="badge badge-outline gap-1">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Exclusive content
        </span>
        <span class="badge badge-outline gap-1">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Early access
        </span>
        <span class="badge badge-outline gap-1">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
          </svg>
          Premium support
        </span>
      </div>
      
      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        {isAuthenticated ? (
          <a href="/pricing" class="btn btn-primary btn-lg">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"></path>
            </svg>
            Upgrade to Premium
          </a>
        ) : (
          <>
            <a href="/login" class="btn btn-primary btn-lg">
              Sign In
            </a>
            <a href="/pricing" class="btn btn-outline btn-lg">
              View Plans
            </a>
          </>
        )}
      </div>
    </div>
  </div>
</div>
