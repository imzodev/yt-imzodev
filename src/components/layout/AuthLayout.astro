---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../Navbar.astro';

export interface Props {
  title: string;
  heading: string;
  subheading?: string;
  icon?: boolean;
}

const { title, heading, subheading, icon = true } = Astro.props;
---

<Layout title={title}>
  <Navbar />
  <main class="min-h-screen flex items-center justify-center bg-base-200 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8">
      <div>
        {icon && (
          <div class="mx-auto h-12 w-12 flex items-center justify-center rounded-full bg-primary/10">
            <slot name="icon">
              <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
              </svg>
            </slot>
          </div>
        )}
        <h2 class="mt-6 text-center text-3xl font-extrabold text-base-content">
          {heading}
        </h2>
        {subheading && (
          <p class="mt-2 text-center text-sm text-base-content/70" set:html={subheading} />
        )}
        <slot name="subheading-slot" />
      </div>

      <slot />
    </div>
  </main>
</Layout>
