---
export interface Props {
  video: {
    id: number;
    title: string;
    description: string;
    youtube_id: string;
    duration: number;
    published_at: string;
    view_count: number;
    category?: {
      name: string;
      slug: string;
    };
  };
}

const { video } = Astro.props;

// Format duration from seconds to MM:SS
const formatDuration = (seconds: number) => {
  const m = Math.floor(seconds / 60);
  const s = seconds % 60;
  return `${m}:${s.toString().padStart(2, '0')}`;
};

// Format date
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  }).format(date);
};
---

<a href={`/videos/${video.id}`} class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow duration-200">
  <figure class="relative aspect-video">
    <img 
      src={`https://img.youtube.com/vi/${video.youtube_id}/maxresdefault.jpg`} 
      alt={video.title} 
      class="object-cover w-full h-full"
      loading="lazy"
    />
    <div class="absolute bottom-2 right-2 bg-base-300/90 text-base-content px-2 py-1 text-xs rounded font-medium">
      {formatDuration(video.duration)}
    </div>
  </figure>
  <div class="card-body p-5">
    {video.category && (
      <div class="badge badge-primary badge-sm mb-2">{video.category.name}</div>
    )}
    <h2 class="card-title text-lg line-clamp-2 leading-tight" title={video.title}>
      {video.title}
    </h2>
    <div class="flex items-center text-sm text-base-content/70 mt-auto pt-4 space-x-4">
      <span class="flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
        </svg>
        {video.view_count.toLocaleString()}
      </span>
      <span class="flex items-center">
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        {formatDate(video.published_at)}
      </span>
    </div>
  </div>
</a>
