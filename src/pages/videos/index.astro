---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import VideoCard from '../../components/video/VideoCard.astro';
import { supabase } from '../../lib/supabase';

// Fetch all categories
const { data: categories } = await supabase
  .from('video_categories')
  .select('*')
  .order('name');

// Get selected category from URL
const selectedCategory = Astro.url.searchParams.get('category');

// Fetch videos
let query = supabase
  .from('videos')
  .select(`
    *,
    category:video_categories(name, slug)
  `)
  .eq('is_active', true)
  .order('published_at', { ascending: false });

if (selectedCategory) {
  query = query.eq('category:video_categories.slug', selectedCategory);
}

const { data: videos, error } = await query;
---

<Layout title="Videos - YouTube Community Portal">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-12 px-4 sm:px-6 lg:px-8 mt-16">
    <div class="max-w-7xl mx-auto space-y-8">
      
      <!-- Header -->
      <div class="text-center sm:text-left sm:flex sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-extrabold text-base-content sm:text-4xl">
            Video Library
          </h1>
          <p class="mt-3 text-xl text-base-content/70">
            Latest tutorials, vlogs, and tech reviews.
          </p>
        </div>
      </div>

      <!-- Categories Filter -->
      <div class="flex flex-wrap gap-2 pb-4 border-b border-base-300">
        <a 
          href="/videos" 
          class={`btn btn-sm ${!selectedCategory ? 'btn-primary' : 'btn-ghost border border-base-300'}`}
        >
          All
        </a>
        {categories?.map((cat) => (
          <a 
            href={`/videos?category=${cat.slug}`}
            class={`btn btn-sm ${selectedCategory === cat.slug ? 'btn-primary' : 'btn-ghost border border-base-300'}`}
          >
            {cat.name}
          </a>
        ))}
      </div>

      <!-- Video Grid -->
      {error ? (
        <div class="alert alert-error">Failed to load videos.</div>
      ) : videos && videos.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {videos.map((video) => (
            <VideoCard video={video} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-base-100 rounded-lg shadow">
          <svg class="mx-auto h-12 w-12 text-base-content/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-base-content">No videos</h3>
          <p class="mt-1 text-sm text-base-content/70">Check back later for new content.</p>
        </div>
      )}
    </div>
  </main>
</Layout>
