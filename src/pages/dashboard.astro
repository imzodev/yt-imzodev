---
import MemberLayout from '../components/member/MemberLayout.astro';
import { getSession } from '../lib/server/auth';
import { getUserDashboardData } from '../lib/server/dashboard';
import { getViewerBySupabaseId } from '../lib/server/forum';

export const prerender = false;

// Check if user is authenticated
const authResult = await getSession(Astro, { requireAuth: true });
if (authResult instanceof Response) return authResult;
const { user } = authResult;

// Get viewer profile and dashboard data
const viewer = await getViewerBySupabaseId(user!.id);
const dashboardData = viewer ? await getUserDashboardData(viewer.id) : null;

// Lab tools list
const labTools = [
  { name: 'Code Formatter', slug: 'code-formatter', icon: '🎨' },
  { name: 'Color Palette', slug: 'color-palette', icon: '🎨' },
  { name: 'Regex Tester', slug: 'regex-tester', icon: '🔍' },
  { name: 'JSON Validator', slug: 'json-validator', icon: '✓' },
  { name: 'Password Generator', slug: 'password-generator', icon: '🔐' },
];

// Format date helper
function formatDate(date: Date | null): string {
  if (!date) return 'N/A';
  const d = new Date(date);
  const now = new Date();
  const diff = now.getTime() - d.getTime();
  const days = Math.floor(diff / (1000 * 60 * 60 * 24));
  
  if (days === 0) return 'Today';
  if (days === 1) return 'Yesterday';
  if (days < 7) return `${days} days ago`;
  return d.toLocaleDateString();
}
---

<MemberLayout 
  title="Dashboard" 
  description="Your personalized member hub"
  activeNav="dashboard"
>
  <!-- Welcome Section -->
  <div class="bg-gradient-to-r from-primary/10 to-secondary/10 rounded-lg p-6 mb-6">
    <h2 class="text-2xl font-bold mb-2">
      Welcome back, {viewer?.name || viewer?.username || 'Member'}! 👋
    </h2>
    <p class="text-base-content/70">
      Your personalized dashboard with everything you need to engage with the community.
    </p>
  </div>

  <!-- Stats Overview -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="stats shadow">
      <div class="stat">
        <div class="stat-title">Forum Posts</div>
        <div class="stat-value text-primary">{dashboardData?.stats.forumPosts || 0}</div>
      </div>
    </div>
    <div class="stats shadow">
      <div class="stat">
        <div class="stat-title">Replies</div>
        <div class="stat-value text-secondary">{dashboardData?.stats.forumReplies || 0}</div>
      </div>
    </div>
    <div class="stats shadow">
      <div class="stat">
        <div class="stat-title">Comments</div>
        <div class="stat-value text-accent">{dashboardData?.stats.blogComments || 0}</div>
      </div>
    </div>
    <div class="stats shadow">
      <div class="stat">
        <div class="stat-title">Videos Watched</div>
        <div class="stat-value text-info">{dashboardData?.stats.videoViews || 0}</div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left Column: Forum Activity & Recent Videos -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Forum Activity -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <div class="flex items-center justify-between mb-4">
            <h3 class="card-title">💬 Your Forum Activity</h3>
            <a href="/forum" class="btn btn-primary btn-sm">View Forum</a>
          </div>
          {dashboardData?.forumActivity && dashboardData.forumActivity.length > 0 ? (
            <div class="space-y-3">
              {dashboardData.forumActivity.map((item) => (
                <a href={`/forum/thread/${item.postId}`} class="block p-3 rounded-lg hover:bg-base-200 transition-colors">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <p class="font-medium">{item.title}</p>
                      <div class="flex items-center gap-3 mt-1 text-sm text-base-content/60">
                        <span class="badge badge-sm">{item.type}</span>
                        <span>{formatDate(item.createdAt)}</span>
                        {item.type === 'post' && item.replyCount > 0 && (
                          <span>{item.replyCount} replies</span>
                        )}
                      </div>
                    </div>
                    <svg class="w-5 h-5 text-base-content/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-8">
              <svg class="w-12 h-12 mx-auto text-base-content/20 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z"/>
              </svg>
              <p class="text-base-content/60 mb-3">No forum activity yet</p>
              <a href="/forum" class="btn btn-primary btn-sm">Start a Discussion</a>
            </div>
          )}
        </div>
      </div>

      <!-- Recently Watched Videos -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <div class="flex items-center justify-between mb-4">
            <h3 class="card-title">📺 Recently Watched</h3>
            <a href="/videos" class="btn btn-primary btn-sm">Browse Videos</a>
          </div>
          {dashboardData?.recentVideos && dashboardData.recentVideos.length > 0 ? (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {dashboardData.recentVideos.map((video) => (
                <a href={`/videos/${video.id}`} class="group">
                  <div class="relative aspect-video rounded-lg overflow-hidden bg-base-300">
                    {video.thumbnail ? (
                      <img src={video.thumbnail} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <svg class="w-12 h-12 text-base-content/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                      </div>
                    )}
                    {video.duration && (
                      <div class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-2 py-1 rounded">
                        {video.duration}
                      </div>
                    )}
                  </div>
                  <p class="mt-2 font-medium line-clamp-2 group-hover:text-primary transition-colors">{video.title}</p>
                  <p class="text-xs text-base-content/60 mt-1">Watched {formatDate(video.viewedAt)}</p>
                </a>
              ))}
            </div>
          ) : (
            <div class="text-center py-8">
              <svg class="w-12 h-12 mx-auto text-base-content/20 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <p class="text-base-content/60 mb-3">No videos watched yet</p>
              <a href="/videos" class="btn btn-primary btn-sm">Explore Videos</a>
            </div>
          )}
        </div>
      </div>
    </div>

    <!-- Right Column: Lab Tools & Subscription -->
    <div class="space-y-6">
      <!-- Lab Tools Quick Access -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <div class="flex items-center justify-between mb-4">
            <h3 class="card-title">🧪 Lab Tools</h3>
            <a href="/lab" class="btn btn-ghost btn-sm">View All</a>
          </div>
          <div class="space-y-2">
            {labTools.map((tool) => (
              <a href={`/lab/${tool.slug}`} class="btn btn-outline btn-sm w-full justify-start">
                <span class="mr-2">{tool.icon}</span>
                {tool.name}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Subscription Status -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <h3 class="card-title mb-4">💎 Subscription</h3>
          <div class="text-center">
            <div class={`badge badge-lg ${viewer?.subscriptionTier === 'premium' ? 'badge-warning' : 'badge-ghost'} mb-3`}>
              {viewer?.subscriptionTier === 'premium' ? 'Premium Member' : 'Free Member'}
            </div>
            {viewer?.subscriptionTier === 'premium' ? (
              <div>
                <p class="text-sm text-base-content/70 mb-4">You have access to all premium features!</p>
                <a href="/profile" class="btn btn-sm btn-outline w-full">Manage Subscription</a>
              </div>
            ) : (
              <div>
                <p class="text-sm text-base-content/70 mb-3">Upgrade to unlock premium content and features</p>
                <ul class="text-left text-sm space-y-2 mb-4">
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Premium videos
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Advanced search
                  </li>
                  <li class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Priority support
                  </li>
                </ul>
                <a href="/pricing" class="btn btn-primary btn-sm w-full">Upgrade Now</a>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Premium Support - Only shown for premium subscribers */}
      {viewer?.subscriptionTier === 'premium' && (
        <div class="card bg-base-100 shadow-lg border border-primary/20">
          <div class="card-body">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center">
                <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <div>
                <h3 class="card-title">Premium Support</h3>
                <p class="text-sm text-base-content/70">Priority support for premium members</p>
              </div>
            </div>
            <div class="space-y-2">
              <a 
                href="mailto:support@imzodev.com" 
                class="flex items-center gap-3 p-3 rounded-lg hover:bg-base-200 transition-colors group"
              >
                <div class="w-8 h-8 rounded bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                  <svg class="w-4 h-4 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="font-medium text-sm">Email Support</p>
                  <p class="text-xs text-base-content/50">support@imzodev.com</p>
                </div>
                <svg class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
              <a 
                href="https://discord.gg/imzodev" 
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 p-3 rounded-lg hover:bg-base-200 transition-colors group"
              >
                <div class="w-8 h-8 rounded bg-primary/10 flex items-center justify-center group-hover:bg-primary/20 transition-colors">
                  <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.063 1.515c-.018.018-.027.037-.037.056a19.502 19.502 0 0 0-1.97 9.92c0 .04.027.083.055.112a19.9 19.9 0 0 0 5.91 2.992c.037.056.092.056.129.019c.456-.627.861-1.292 1.213-1.992.019-.037.01-.074-.028-.093a13.156 13.156 0 0 1-1.907-.916c-.093-.056-.185-.111-.278-.165-.083-.056-.083-.175 0-.24.055-.037.092-.074.166-.111a14.17 14.17 0 0 0 2.989-.916c.065-.046.129-.093.194-.13.065-.046.157-.037.231.037.037.037.056.093.037.157-.037a14.248 14.248 0 0 0 2.989.916l.166.111c.093.056.185.111.278.166.093.046.175.055.24.037a.212.212 0 0 0 .129-.093 7.153 7.153 0 0 0 1.213 1.992c.037.056.092.056.129.019a19.873 19.873 0 0 0 5.91-2.992c.037-.037.046-.074.046-.112a19.555 19.555 0 0 0-1.97-9.92c0-.018-.01-.037-.028-.056z"/>
                  </svg>
                </div>
                <div class="flex-1">
                  <p class="font-medium text-sm">Discord Community</p>
                  <p class="text-xs text-base-content/50">Get help from the community</p>
                </div>
                <svg class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 6h6m0 0l-3-3m3 3" />
                </svg>
              </a>
              <p class="text-xs text-base-content/50 text-center pt-2">
                Average response time: 24 hours
              </p>
            </div>
          </div>
        </div>
      )}

      <!-- Quick Links -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <h3 class="card-title mb-4">🔗 Quick Links</h3>
          <div class="space-y-2">
            <a href="/blog" class="btn btn-ghost btn-sm w-full justify-start">
              📝 Browse Blog
            </a>
            <a href="/forum/notifications" class="btn btn-ghost btn-sm w-full justify-start">
              🔔 Notifications
            </a>
            <a href="/profile" class="btn btn-ghost btn-sm w-full justify-start">
              ⚙️ Settings
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</MemberLayout>
