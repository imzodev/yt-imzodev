---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Alert from '../components/ui/Alert.astro';
import { getSession } from '../lib/server/auth';

export const prerender = false;

const authResult = await getSession(Astro);
if (authResult instanceof Response) return authResult;
const { user, supabase } = authResult;

let profile = null;
let subscription = null;

if (user) {
  const { data } = await supabase
    .from('users')
    .select('*')
    .eq('supabase_user_id', user.id)
    .single();

  profile = data;

  if (profile?.id) {
    const { data: subscriptionData } = await supabase
      .from('subscriptions')
      .select('*, subscription_plans(name)')
      .eq('user_id', profile.id)
      .in('status', ['active', 'trialing', 'past_due'])
      .order('updated_at', { ascending: false })
      .limit(1)
      .maybeSingle();

    subscription = subscriptionData;
  }
}

const checkoutState = Astro.url.searchParams.get('checkout');
const billingState = Astro.url.searchParams.get('billing');
const trialState = Astro.url.searchParams.get('trial');

const feedbackMessage = checkoutState === 'success'
  ? trialState === 'true'
    ? 'Your 7-day free trial has started! Enjoy Premium access with no payment required until the trial ends.'
    : 'Your checkout was completed. Premium access will appear as soon as Stripe finishes syncing your subscription.'
  : checkoutState === 'canceled'
    ? 'Checkout was canceled. You can restart it anytime.'
    : billingState === 'profile-unavailable'
      ? 'Your billing profile could not be loaded.'
      : billingState === 'checkout-error'
        ? 'We could not start Stripe Checkout right now.'
        : null;

const feedbackType = checkoutState === 'canceled' || billingState ? 'error' : feedbackMessage ? 'success' : null;
---

<Layout
  title="Pricing - imzodev"
  description="Upgrade to Premium for exclusive videos, advanced search, expanded forum participation, and priority support."
>
  <Navbar />
  <main class="min-h-screen bg-base-200 px-4 py-12">
    <div class="mx-auto mt-16 flex max-w-6xl flex-col gap-8">
      <section class="space-y-4 text-center">
        <span class="badge badge-primary badge-lg">Premium Membership</span>
        <h1 class="text-4xl font-black text-base-content">One premium plan. Simple recurring billing.</h1>
        <p class="mx-auto max-w-3xl text-base text-base-content/70">
          Premium unlocks exclusive video content, better discovery tools, expanded community access, and faster support while keeping snippets available to everyone.
        </p>
      </section>

      {feedbackMessage && feedbackType && (
        <Alert type={feedbackType} message={feedbackMessage} />
      )}

      <section class="grid gap-8 lg:grid-cols-[1.2fr,0.8fr]">
        <article class="card bg-base-100 shadow-xl">
          <div class="card-body gap-6">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <h2 class="card-title text-3xl">Premium</h2>
                <p class="text-base-content/70">Recurring monthly access to premium content and perks.</p>
              </div>
              <div class="text-right">
                <div class="text-4xl font-black">$9.99</div>
                <div class="text-sm text-base-content/60">per month</div>
              </div>
            </div>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="rounded-2xl border border-base-300 bg-base-200/70 p-4">
                <h3 class="font-semibold">Included</h3>
                <ul class="mt-3 space-y-2 text-sm text-base-content/70">
                  <li>Premium videos and gated content</li>
                  <li>Advanced search and discovery tools</li>
                  <li>Expanded forum participation</li>
                  <li>Priority support and early access</li>
                </ul>
              </div>
              <div class="rounded-2xl border border-base-300 bg-base-200/70 p-4">
                <h3 class="font-semibold">Always available to everyone</h3>
                <ul class="mt-3 space-y-2 text-sm text-base-content/70">
                  <li>Public videos and blog posts</li>
                  <li>Community browsing</li>
                  <li>Global snippet library</li>
                  <li>Account profile and basic search</li>
                </ul>
              </div>
            </div>

            {user ? (
              subscription ? (
                <form method="POST" action="/api/billing/portal" class="space-y-4">
                  <div class="rounded-2xl border border-success/20 bg-success/10 p-4 text-sm text-success">
                    You already have an active billing record for {subscription.subscription_plans?.name || 'Premium'}.
                  </div>
                  <button type="submit" class="btn btn-outline btn-primary w-full">Manage Billing</button>
                </form>
              ) : (
                <form method="POST" action="/api/billing/checkout" class="space-y-4">
                  
                  <!-- Trial option -->
                  <label class="flex items-start gap-3 cursor-pointer rounded-xl border border-primary/20 bg-primary/5 p-4 hover:border-primary/40 transition">
                    <input type="checkbox" name="trial" value="true" class="checkbox checkbox-primary checkbox-sm mt-0.5" checked />
                    <div class="flex-1">
                      <span class="font-semibold text-base-content">Start with 7-day free trial</span>
                      <p class="text-sm text-base-content/60 mt-0.5">Try Premium risk-free. No payment required until the trial ends.</p>
                    </div>
                  </label>
                  
                  <button type="submit" class="btn btn-primary btn-lg w-full">Start Premium Membership</button>
                  <p class="text-center text-xs text-base-content/50">You'll be redirected to Stripe Checkout to finish your subscription securely.</p>
                </form>
              )
            ) : (
              <div class="space-y-4">
                <a href="/login?next=/pricing" class="btn btn-primary btn-lg w-full">Log in to upgrade</a>
                <p class="text-center text-xs text-base-content/50">Create or sign in to your account before starting checkout.</p>
              </div>
            )}
          </div>
        </article>

        <aside class="card bg-base-100 shadow-xl">
          <div class="card-body gap-4">
            <h2 class="card-title text-xl">Billing snapshot</h2>
            <div class="space-y-3 text-sm">
              <div class="flex items-center justify-between">
                <span class="text-base-content/60">Plan</span>
                <span class="font-semibold">Premium</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-base-content/60">Billing cadence</span>
                <span class="font-semibold">Monthly</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-base-content/60">Currency</span>
                <span class="font-semibold">USD</span>
              </div>
              <div class="flex items-center justify-between">
                <span class="text-base-content/60">Current account state</span>
                <span class="font-semibold">{subscription ? 'Premium' : profile ? 'Free' : 'Guest'}</span>
              </div>
            </div>

            <div class="divider my-1"></div>

            <div class="space-y-3 text-sm text-base-content/70">
              <p>Billing is managed through Stripe. Premium access is synchronized back into your account through Stripe webhooks.</p>
              <p>If you already subscribed but do not see Premium access yet, refresh this page after a moment or reopen the billing portal.</p>
            </div>
          </div>
        </aside>
      </section>
    </div>
  </main>
</Layout>
