---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import VideoCard from '../../components/video/VideoCard.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import SnippetCard from '../../components/snippet/SnippetCard.astro';
import { supabase } from '../../lib/supabase';

const query = Astro.url.searchParams.get('q') || '';
const type = Astro.url.searchParams.get('type') || 'all'; // all, videos, blog, snippets

let videos: any[] = [];
let posts: any[] = [];
let snippets: any[] = [];

if (query) {
  // We use ilike for simple text search. In production, consider Supabase Full Text Search
  const searchTerm = `%${query}%`;
  
  if (type === 'all' || type === 'videos') {
    const { data } = await supabase
      .from('videos')
      .select('*, category:video_categories(name, slug)')
      .or(`title.ilike.${searchTerm},description.ilike.${searchTerm}`)
      .eq('is_active', true)
      .limit(12);
    if (data) videos = data;
  }

  if (type === 'all' || type === 'blog') {
    const { data } = await supabase
      .from('blog_posts')
      .select('*, category:blog_categories(name, slug), author:users(name, avatar)')
      .or(`title.ilike.${searchTerm},excerpt.ilike.${searchTerm},content.ilike.${searchTerm}`)
      .eq('status', 'published')
      .limit(12);
    if (data) posts = data;
  }

  if (type === 'all' || type === 'snippets') {
    const { data } = await supabase
      .from('snippets')
      .select('*, category:snippet_categories(name, slug), author:users(name, avatar)')
      .or(`title.ilike.${searchTerm},description.ilike.${searchTerm},language.ilike.${searchTerm}`)
      .limit(12);
    if (data) snippets = data;
  }
}

const totalResults = videos.length + posts.length + snippets.length;
---

<Layout title="Search - YouTube Community Portal">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-12 px-4 sm:px-6 lg:px-8 mt-16">
    <div class="max-w-7xl mx-auto space-y-8">
      
      <!-- Search Header -->
      <div class="bg-base-100 rounded-xl shadow-sm p-6 md:p-8">
        <h1 class="text-3xl font-extrabold text-base-content mb-6">Search Results</h1>
        
        <form action="/search" method="GET" class="flex flex-col sm:flex-row gap-4">
          <div class="grow">
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-5 w-5 text-base-content/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>
              <input
                type="text"
                name="q"
                value={query}
                placeholder="Search videos, articles, snippets..."
                class="input input-bordered w-full pl-10"
                required
              />
            </div>
          </div>
          <select name="type" class="select select-bordered sm:w-auto" onchange="this.form.submit()">
            <option value="all" selected={type === 'all'}>All Content</option>
            <option value="videos" selected={type === 'videos'}>Videos</option>
            <option value="blog" selected={type === 'blog'}>Blog Posts</option>
            <option value="snippets" selected={type === 'snippets'}>Code Snippets</option>
          </select>
          <button type="submit" class="btn btn-primary">Search</button>
        </form>

        {query && (
          <p class="mt-4 text-sm text-base-content/70">
            Found {totalResults} result{totalResults !== 1 ? 's' : ''} for "<span class="font-medium text-base-content">{query}</span>"
          </p>
        )}
      </div>

      <!-- Results -->
      {query ? (
        <div class="space-y-12">
          {/* Videos */}
          {videos.length > 0 && (
            <section>
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-bold text-base-content">Videos</h2>
                {type === 'all' && videos.length >= 12 && (
                  <a href={`/search?q=${query}&type=videos`} class="text-primary hover:underline text-sm font-medium">View all video results</a>
                )}
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                {videos.map(video => <VideoCard video={video} />)}
              </div>
            </section>
          )}

          {/* Blog Posts */}
          {posts.length > 0 && (
            <section>
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-bold text-base-content">Articles</h2>
                {type === 'all' && posts.length >= 12 && (
                  <a href={`/search?q=${query}&type=blog`} class="text-primary hover:underline text-sm font-medium">View all article results</a>
                )}
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {posts.map(post => <BlogCard post={post} />)}
              </div>
            </section>
          )}

          {/* Snippets */}
          {snippets.length > 0 && (
            <section>
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-2xl font-bold text-base-content">Code Snippets</h2>
                {type === 'all' && snippets.length >= 12 && (
                  <a href={`/search?q=${query}&type=snippets`} class="text-primary hover:underline text-sm font-medium">View all snippet results</a>
                )}
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {snippets.map(snippet => <SnippetCard snippet={snippet} />)}
              </div>
            </section>
          )}

          {totalResults === 0 && (
            <div class="text-center py-16 bg-base-100 rounded-xl shadow-sm border border-base-200">
              <svg class="mx-auto h-16 w-16 text-base-content/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <h3 class="mt-4 text-lg font-medium text-base-content">No results found</h3>
              <p class="mt-2 text-base-content/70 max-w-md mx-auto">
                We couldn't find anything matching "{query}". Try checking for spelling errors or using more general terms.
              </p>
            </div>
          )}
        </div>
      ) : (
        <div class="text-center py-16 bg-base-100 rounded-xl shadow-sm border border-base-200">
          <svg class="mx-auto h-16 w-16 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-base-content">Search for anything</h3>
          <p class="mt-2 text-base-content/70">
            Find tutorials, articles, and code snippets across the entire platform.
          </p>
        </div>
      )}

    </div>
  </main>
</Layout>
