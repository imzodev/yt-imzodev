---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="imzodev - AI & Software Development">
  <Navbar />
  <div class="min-h-screen bg-[#0a0e27]">
    <!-- Hero Section -->
    <div class="container mx-auto px-4 pt-20 pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div>
          <div class="badge badge-primary badge-outline mb-6">🚀 WELCOME TO IMZODEV</div>
          <h1 class="text-5xl lg:text-6xl font-bold text-white mb-6">
            Master <span class="text-primary">AI</span> &<br/>
            Software<br/>
            Development
          </h1>
          <p class="text-gray-400 text-lg mb-8 max-w-lg">
            Deep-dive into AI and software insights from the frontier of coding, neural networks, and scalable architecture.
          </p>
          <div class="flex gap-4">
            <a href="#videos" class="btn btn-primary gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
              Watch Latest Video
            </a>
            <a href="#guides" class="btn btn-outline btn-primary">View Guides</a>
          </div>
        </div>
        
        <!-- Right Content - Tech Visual -->
        <div class="hidden lg:block">
          <div class="relative bg-gradient-to-br from-primary/10 to-secondary/10 rounded-2xl p-8 border border-primary/20">
            <div class="aspect-video bg-[#0f1535] rounded-lg flex items-center justify-center">
              <svg class="w-32 h-32 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Trending Tutorials Section -->
    <div class="container mx-auto px-4 py-16">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-3xl font-bold text-white">Trending Tutorials</h2>
          <p class="text-gray-400 mt-2">Master the most sought-after topics this week</p>
        </div>
        <a href="/tutorials" class="text-primary hover:underline">View All →</a>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card bg-[#0f1535] shadow-xl hover:shadow-2xl transition-all border border-primary/10">
          <figure class="aspect-video bg-gradient-to-br from-primary/20 to-secondary/20 relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-20 h-20 text-white/20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="absolute bottom-2 right-2 badge badge-sm">12:45</div>
          </figure>
          <div class="card-body">
            <h3 class="card-title text-white text-lg">Building a GPT-4 Powered SaaS</h3>
            <p class="text-gray-400 text-sm">Learn how to integrate LLMs into your production-ready SaaS platform.</p>
            <div class="flex items-center gap-2 mt-2">
              <div class="avatar placeholder">
                <div class="bg-primary text-primary-content rounded-full w-6">
                  <span class="text-xs">I</span>
                </div>
              </div>
              <span class="text-xs text-gray-500">imzodev</span>
            </div>
          </div>
        </div>

        <div class="card bg-[#0f1535] shadow-xl hover:shadow-2xl transition-all border border-primary/10">
          <figure class="aspect-video bg-gradient-to-br from-secondary/20 to-accent/20 relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-20 h-20 text-white/20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="absolute bottom-2 right-2 badge badge-sm">18:32</div>
          </figure>
          <div class="card-body">
            <h3 class="card-title text-white text-lg">Neural Networks from Scratch</h3>
            <p class="text-gray-400 text-sm">We dive into math, code, and intuition to build a CNN from scratch.</p>
            <div class="flex items-center gap-2 mt-2">
              <div class="avatar placeholder">
                <div class="bg-primary text-primary-content rounded-full w-6">
                  <span class="text-xs">I</span>
                </div>
              </div>
              <span class="text-xs text-gray-500">imzodev</span>
            </div>
          </div>
        </div>

        <div class="card bg-[#0f1535] shadow-xl hover:shadow-2xl transition-all border border-primary/10">
          <figure class="aspect-video bg-gradient-to-br from-accent/20 to-primary/20 relative overflow-hidden">
            <div class="absolute inset-0 flex items-center justify-center">
              <svg class="w-20 h-20 text-white/20" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <div class="absolute bottom-2 right-2 badge badge-sm">25:18</div>
          </figure>
          <div class="card-body">
            <h3 class="card-title text-white text-lg">Next.js 14 App Router Deep Dive</h3>
            <p class="text-gray-400 text-sm">Everything you need to know about Next.js App Router, Suspense, and more.</p>
            <div class="flex items-center gap-2 mt-2">
              <div class="avatar placeholder">
                <div class="bg-primary text-primary-content rounded-full w-6">
                  <span class="text-xs">I</span>
                </div>
              </div>
              <span class="text-xs text-gray-500">imzodev</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Deep-Dive Guides Section -->
    <div id="guides" class="container mx-auto px-4 py-16">
      <h2 class="text-3xl font-bold text-white mb-8">Deep-Dive Guides</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="card bg-[#0f1535] hover:bg-[#141a42] transition-all border border-primary/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-primary/20 rounded-lg">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-white">The 2024 AI Roadmap</h3>
                <p class="text-gray-400 text-sm mt-2">A comprehensive guide on how to learn AI and ML in 2024 for beginners and pros.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-[#0f1535] hover:bg-[#141a42] transition-all border border-primary/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-secondary/20 rounded-lg">
                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-white">Scalable Microservices</h3>
                <p class="text-gray-400 text-sm mt-2">A practical approach to building and scaling microservices with Kubernetes and gRPC.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-[#0f1535] hover:bg-[#141a42] transition-all border border-primary/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-accent/20 rounded-lg">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-white">Auth in 2024</h3>
                <p class="text-gray-400 text-sm mt-2">Modern OAuth 2.0, JWT, and session management for secure applications.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-[#0f1535] hover:bg-[#141a42] transition-all border border-primary/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-info/20 rounded-lg">
                <svg class="w-6 h-6 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-white">Vector Databases Explained</h3>
                <p class="text-gray-400 text-sm mt-2">Why Pinecone and Weaviate are essential for RAG and AI apps in 2024.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Free Developer Resources Section -->
    <div class="bg-primary py-16">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Free Developer Resources</h2>
        <p class="text-primary-content/80 mb-12 max-w-2xl mx-auto">
          Curated lists of tools, libraries, and guides I use day-to-day to build software and train models.
        </p>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <span class="text-white font-medium">VS Code Extensions</span>
          </div>
          
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <span class="text-white font-medium">Productivity Tools</span>
          </div>
          
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
              </svg>
            </div>
            <span class="text-white font-medium">Dataset Sources</span>
          </div>
          
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <span class="text-white font-medium">API Directory</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Newsletter Section -->
    <div class="bg-[#0f1535] py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-white mb-4">Stay ahead of the curve</h2>
          <p class="text-gray-400 mb-8">
            Join 50,000+ developers getting weekly tutorials, tips, and insights on AI, software, and tech trends.
          </p>
          
          <form class="flex gap-4 max-w-md mx-auto">
            <input 
              type="email" 
              placeholder="Enter your email" 
              class="input input-bordered flex-1 bg-[#0a0e27] border-primary/20 text-white placeholder:text-gray-500"
              required
            />
            <button type="submit" class="btn btn-primary">Join Newsletter</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>
