---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import VideoCard from '../components/video/VideoCard.astro';
import { supabase } from '../lib/supabase';

// Fetch latest videos (limit to 3 for homepage)
const { data: latestVideos } = await supabase
  .from('videos')
  .select(`
    *,
    category:video_categories(name, slug)
  `)
  .eq('is_active', true)
  .order('published_at', { ascending: false })
  .limit(3);
---

<Layout title="imzodev - AI & Software Development">
  <Navbar />
  <div class="min-h-screen bg-base-100 text-base-content">
    <!-- Hero Section -->
    <div class="container mx-auto px-4 pt-20 pb-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left Content -->
        <div>
          <div class="badge badge-primary badge-outline mb-6">🚀 WELCOME TO IMZODEV</div>
          <h1 class="text-5xl lg:text-6xl font-bold text-base-content mb-6">
            Master <span class="text-primary">AI</span> &<br/>
            Software<br/>
            Development
          </h1>
          <p class="text-base-content/70 text-lg mb-8 max-w-lg">
            Deep-dive into AI and software insights from frontier of coding, neural networks, and scalable architecture.
          </p>
          <div class="flex gap-4">
            <a href="#videos" class="btn btn-primary gap-2">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
              Watch Latest Video
            </a>
            <a href="#guides" class="btn btn-outline btn-primary">View Guides</a>
          </div>
        </div>
        
        <!-- Right Content - Tech Visual -->
        <div class="hidden lg:block">
          <div class="relative bg-gradient-to-br from-primary/10 to-secondary/10 rounded-2xl p-8 border border-primary/20">
            <div class="aspect-video bg-base-200 rounded-lg flex items-center justify-center">
              <svg class="w-32 h-32 text-primary/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Latest Videos Section -->
    <div id="videos" class="container mx-auto px-4 py-16">
      <div class="flex justify-between items-center mb-8">
        <div>
          <h2 class="text-3xl font-bold text-base-content">Latest Videos</h2>
          <p class="text-base-content/70 mt-2">Fresh tutorials, insights, and tech updates</p>
        </div>
        <a href="/videos" class="text-primary hover:underline">View All →</a>
      </div>

      {latestVideos && latestVideos.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestVideos.map((video) => (
            <VideoCard video={video} />
          ))}
        </div>
      ) : (
        <div class="bg-base-200 rounded-lg p-12 text-center">
          <svg class="mx-auto h-16 w-16 text-base-content/30 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
          </svg>
          <h3 class="text-xl font-semibold text-base-content mb-2">No videos yet</h3>
          <p class="text-base-content/70 max-w-md mx-auto">
            Videos from <a href="https://youtube.com/@imzodev" target="_blank" class="text-primary hover:underline">@imzodev</a> will appear here once synced to the database.
          </p>
          <a href="https://youtube.com/@imzodev" target="_blank" class="btn btn-primary mt-6">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505a3.017 3.017 0 0 0-2.122 2.136C.242 8.273 0 8.273 0 12s.242 3.727.505 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24.002 15.727 24.244 12 24.244 12s-.242-3.727-.505-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
            </svg>
            Visit YouTube Channel
          </a>
        </div>
      )}
    </div>

    <!-- Deep-Dive Guides Section -->
    <div id="guides" class="container mx-auto px-4 py-16">
      <h2 class="text-3xl font-bold text-base-content mb-8">Deep-Dive Guides</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="card bg-base-200 hover:bg-base-300 transition-all border border-primary/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-primary/20 rounded-lg">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-base-content">The 2024 AI Roadmap</h3>
                <p class="text-base-content/70 text-sm mt-2">A comprehensive guide on how to learn AI and ML in 2024 for beginners and pros.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 hover:bg-base-300 transition-all border border-secondary/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-secondary/20 rounded-lg">
                <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-base-content">Scalable Microservices</h3>
                <p class="text-base-content/70 text-sm mt-2">A practical approach to building and scaling microservices with Kubernetes and gRPC.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 hover:bg-base-300 transition-all border border-accent/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-accent/20 rounded-lg">
                <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-base-content">Auth in 2024</h3>
                <p class="text-base-content/70 text-sm mt-2">Modern OAuth 2.0, JWT, and session management for secure applications.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 hover:bg-base-300 transition-all border border-info/10">
          <div class="card-body">
            <div class="flex items-start gap-4">
              <div class="p-3 bg-info/20 rounded-lg">
                <svg class="w-6 h-6 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
                </svg>
              </div>
              <div class="flex-1">
                <h3 class="card-title text-base-content">Vector Databases Explained</h3>
                <p class="text-base-content/70 text-sm mt-2">Why Pinecone and Weaviate are essential for RAG and AI apps in 2024.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Free Developer Resources Section -->
    <div class="bg-primary py-16">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Free Developer Resources</h2>
        <p class="text-primary-content/80 mb-12 max-w-2xl mx-auto">
          Curated lists of tools, libraries, and guides I use day-to-day to build software and train models.
        </p>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
              </svg>
            </div>
            <span class="text-white font-medium">VS Code Extensions</span>
          </div>
          
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            <span class="text-white font-medium">Productivity Tools</span>
          </div>
          
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
              </svg>
            </div>
            <span class="text-white font-medium">Dataset Sources</span>
          </div>
          
          <div class="flex flex-col items-center gap-3">
            <div class="p-4 bg-white/10 rounded-lg">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <span class="text-white font-medium">API Directory</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Newsletter Section -->
    <div class="bg-base-200 py-16">
      <div class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto text-center">
          <h2 class="text-3xl font-bold text-base-content mb-4">Stay ahead of curve</h2>
          <p class="text-base-content/70 mb-8">
            Join 50,000+ developers getting weekly tutorials, tips, and insights on AI, software, and tech trends.
          </p>
          
          <form class="flex gap-4 max-w-md mx-auto">
            <input 
              type="email" 
              placeholder="Enter your email" 
              class="input input-bordered flex-1 bg-base-100 border-primary/20 text-base-content placeholder:text-base-content/50"
              required
            />
            <button type="submit" class="btn btn-primary">Join Newsletter</button>
          </form>
        </div>
      </div>
    </div>
  </div>
</Layout>
