---
/**
 * URL Shortener Lab Tool
 * Generate short URLs for easy sharing
 */
import MemberLayout from '../../components/member/MemberLayout.astro';
import { getSession } from '../../lib/server/auth';

export const prerender = false;

// Check authentication
const authResult = await getSession(Astro, { requireAuth: true });
if (authResult instanceof Response) return authResult;
---

<MemberLayout 
  title="URL Shortener" 
  description="Create short, shareable links"
  activeNav="lab"
>
  <div class="max-w-2xl mx-auto space-y-6">
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-2">🔗 URL Shortener</h1>
      <p class="text-base-content/70">Create short, memorable links for easy sharing</p>
    </div>

    <!-- Input Form -->
    <div class="card bg-base-100 shadow-lg">
      <div class="card-body">
        <form id="shorten-form" class="space-y-4">
          <div class="form-control">
            <label class="label" for="url-input">
              <span class="label-text font-medium">Long URL</span>
            </label>
            <input 
              type="url" 
              id="url-input" 
              name="url"
              placeholder="https://example.com/very/long/url/that/needs/shortening"
              class="input input-bordered w-full"
              required
            />
            <label class="label">
              <span class="label-text-alt text-base-content/50">Enter the URL you want to shorten</span>
            </label>
          </div>

          <div class="form-control">
            <label class="label" for="custom-code">
              <span class="label-text font-medium">Custom Code (optional)</span>
            </label>
            <div class="join w-full">
              <span class="join-item bg-base-200 px-4 flex items-center border border-base-300">
                {Astro.site?.toString() || 'https://imzodev.com'}/s/
              </span>
              <input 
                type="text" 
                id="custom-code" 
                name="customCode"
                placeholder="my-custom-link"
                class="input input-bordered join-item flex-1"
                pattern="[a-zA-Z0-9_-]+"
                title="Letters, numbers, underscores, and hyphens only"
              />
            </div>
            <label class="label">
              <span class="label-text-alt text-base-content/50">Leave empty for auto-generated code</span>
            </label>
          </div>

          <button type="submit" id="submit-btn" class="btn btn-primary w-full">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            Shorten URL
          </button>
        </form>
      </div>
    </div>

    <!-- Result Card (hidden by default) -->
    <div id="result-card" class="card bg-base-100 shadow-lg hidden">
      <div class="card-body">
        <h2 class="card-title text-success">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Shortened!
        </h2>
        
        <div class="form-control">
          <label class="label">
            <span class="label-text">Your short URL</span>
          </label>
          <div class="join w-full">
            <input 
              type="text" 
              id="short-url" 
              class="input input-bordered join-item flex-1 font-mono"
              readonly
            />
            <button type="button" id="copy-btn" class="btn btn-primary join-item">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
              </svg>
              Copy
            </button>
          </div>
        </div>

        <div class="text-sm text-base-content/50 mt-2">
          <p>Original URL: <a id="original-url" href="#" target="_blank" class="link link-hover"></a></p>
        </div>
      </div>
    </div>

    <!-- Error Card (hidden by default) -->
    <div id="error-card" class="alert alert-error hidden">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.468 0L3.06 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <span id="error-message">An error occurred</span>
    </div>

    <!-- Recent Links -->
    <div class="card bg-base-100 shadow-lg">
      <div class="card-body">
        <h2 class="card-title">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Recent Links
        </h2>
        <div id="recent-links" class="space-y-3">
          <p class="text-base-content/50 text-sm">Your recently shortened URLs will appear here.</p>
        </div>
      </div>
    </div>

    <!-- Info Card -->
    <div class="card bg-base-200 shadow">
      <div class="card-body">
        <h3 class="card-title text-lg">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          How it works
        </h3>
        <ul class="text-sm space-y-2 text-base-content/70">
          <li class="flex items-start gap-2">
            <span class="text-primary">1.</span>
            <span>Paste your long URL into the input field</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary">2.</span>
            <span>Optionally add a custom code or leave blank for auto-generation</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary">3.</span>
            <span>Click "Shorten URL" to generate your short link</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-primary">4.</span>
            <span>Copy and share your short URL!</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</MemberLayout>

<script>
  const form = document.getElementById('shorten-form') as HTMLFormElement;
  const resultCard = document.getElementById('result-card')!;
  const errorCard = document.getElementById('error-card')!;
  const shortUrlInput = document.getElementById('short-url') as HTMLInputElement;
  const originalUrlLink = document.getElementById('original-url') as HTMLAnchorElement;
  const errorMessage = document.getElementById('error-message')!;
  const copyBtn = document.getElementById('copy-btn')!;
  const submitBtn = document.getElementById('submit-btn')!;

  // Load recent links on page load
  updateRecentLinks();

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Hide previous results
    resultCard.classList.add('hidden');
    errorCard.classList.add('hidden');
    
    // Get form data
    const formData = new FormData(form);
    const url = formData.get('url') as string;
    const customCode = formData.get('customCode') as string;
    
    // Disable submit button
    submitBtn.setAttribute('disabled', 'true');
    submitBtn.innerHTML = '<span class="loading loading-spinner loading-sm"></span> Shortening...';
    
    try {
      const response = await fetch('/api/lab/shorten', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({ url, customCode: customCode || undefined }),
      });
      
      const data = await response.json();
      
      if (!response.ok) {
        throw new Error(data.error || 'Failed to shorten URL');
      }
      
      // Show result
      shortUrlInput.value = data.shortUrl;
      originalUrlLink.href = data.originalUrl;
      originalUrlLink.textContent = data.originalUrl.length > 50 
        ? data.originalUrl.substring(0, 50) + '...' 
        : data.originalUrl;
      resultCard.classList.remove('hidden');
      
      // Store in recent links (localStorage)
      saveToRecent(data);
      
    } catch (error) {
      errorMessage.textContent = error instanceof Error ? error.message : 'An error occurred';
      errorCard.classList.remove('hidden');
    } finally {
      submitBtn.removeAttribute('disabled');
      submitBtn.innerHTML = `
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        Shorten URL
      `;
    }
  });

  // Copy to clipboard
  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(shortUrlInput.value);
      copyBtn.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Copied!
      `;
      setTimeout(() => {
        copyBtn.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
          </svg>
          Copy
        `;
      }, 2000);
    } catch (error) {
      console.error('Failed to copy:', error);
    }
  });

  // Save to recent links in localStorage
  function saveToRecent(data: { shortUrl: string; originalUrl: string; code: string }) {
    try {
      const recent = JSON.parse(localStorage.getItem('recent-urls') || '[]');
      recent.unshift({
        ...data,
        createdAt: new Date().toISOString(),
      });
      // Keep only last 5
      const trimmed = recent.slice(0, 5);
      localStorage.setItem('recent-urls', JSON.stringify(trimmed));
      updateRecentLinks();
    } catch (error) {
      console.error('Failed to save recent links:', error);
    }
  }

  // Update recent links display
  function updateRecentLinks() {
    const recentLinksDiv = document.getElementById('recent-links')!;
    try {
      const recent = JSON.parse(localStorage.getItem('recent-urls') || '[]');
      
      if (recent.length === 0) {
        recentLinksDiv.innerHTML = '<p class="text-base-content/50 text-sm">Your recently shortened URLs will appear here.</p>';
        return;
      }
      
      recentLinksDiv.innerHTML = recent.map((item: any) => `
        <div class="flex items-center justify-between p-3 bg-base-200 rounded-lg">
          <div class="flex-1 min-w-0">
            <a href="${item.shortUrl}" target="_blank" class="link link-primary font-mono text-sm">${item.code}</a>
            <p class="text-xs text-base-content/50 truncate">${item.originalUrl}</p>
          </div>
          <button class="btn btn-sm btn-ghost copy-recent" data-url="${item.shortUrl}">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
          </button>
        </div>
      `).join('');
      
      // Add copy handlers for recent links
      document.querySelectorAll('.copy-recent').forEach(btn => {
        btn.addEventListener('click', async () => {
          const urlToCopy = btn.getAttribute('data-url')!;
          await navigator.clipboard.writeText(urlToCopy);
        });
      });
    } catch (error) {
      console.error('Failed to update recent links:', error);
    }
  }
</script>
