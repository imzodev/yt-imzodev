---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="JSON Validator - Lab Tools">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/lab" class="btn btn-ghost btn-sm mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Lab
        </a>
        <h1 class="text-3xl font-bold">JSON Validator</h1>
        <p class="text-base-content/70 mt-2">Validate, format, and explore JSON data</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Input Section -->
        <div class="space-y-6">
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <div class="flex items-center justify-between mb-4">
                <h2 class="card-title">JSON Input</h2>
                <div class="flex gap-2">
                  <button id="clear-btn" class="btn btn-sm btn-ghost">Clear</button>
                  <button id="sample-btn" class="btn btn-sm btn-ghost">Sample</button>
                </div>
              </div>
              <textarea 
                id="json-input"
                class="textarea textarea-bordered font-mono text-sm h-96 w-full"
                placeholder='{"key": "value", "number": 42}'
              ></textarea>
              <div class="flex gap-2 mt-4">
                <button id="validate-btn" class="btn btn-primary flex-1">Validate</button>
                <button id="format-btn" class="btn btn-secondary flex-1">Format</button>
                <button id="minify-btn" class="btn btn-ghost flex-1">Minify</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Output Section -->
        <div class="space-y-6">
          <!-- Status -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <div class="flex items-center justify-between">
                <h2 class="card-title">Status</h2>
                <div id="status-badge" class="badge badge-ghost">Waiting for input</div>
              </div>
              <div id="error-message" class="alert alert-error hidden">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
                <span id="error-text"></span>
              </div>
              <div id="success-message" class="alert alert-success hidden">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Valid JSON</span>
              </div>
            </div>
          </div>

          <!-- Formatted Output -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <div class="flex items-center justify-between mb-4">
                <h2 class="card-title">Formatted Output</h2>
                <button id="copy-btn" class="btn btn-sm btn-ghost" disabled>
                  <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                  Copy
                </button>
              </div>
              <pre id="json-output" class="bg-base-200 p-4 rounded-lg overflow-auto max-h-80 text-sm font-mono">
                <span class="text-base-content/50">Output will appear here</span>
              </pre>
            </div>
          </div>

          <!-- JSON Stats -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <h2 class="card-title">Statistics</h2>
              <div id="json-stats" class="grid grid-cols-2 gap-4 text-sm">
                <div>
                  <div class="text-base-content/70">Type</div>
                  <div id="stat-type" class="font-semibold">-</div>
                </div>
                <div>
                  <div class="text-base-content/70">Size</div>
                  <div id="stat-size" class="font-semibold">-</div>
                </div>
                <div>
                  <div class="text-base-content/70">Keys</div>
                  <div id="stat-keys" class="font-semibold">-</div>
                </div>
                <div>
                  <div class="text-base-content/70">Depth</div>
                  <div id="stat-depth" class="font-semibold">-</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
    const jsonOutput = document.getElementById('json-output') as HTMLPreElement;
    const statusBadge = document.getElementById('status-badge') as HTMLDivElement;
    const errorMessage = document.getElementById('error-message') as HTMLDivElement;
    const errorText = document.getElementById('error-text') as HTMLSpanElement;
    const successMessage = document.getElementById('success-message') as HTMLDivElement;
    const validateBtn = document.getElementById('validate-btn') as HTMLButtonElement;
    const formatBtn = document.getElementById('format-btn') as HTMLButtonElement;
    const minifyBtn = document.getElementById('minify-btn') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
    const sampleBtn = document.getElementById('sample-btn') as HTMLButtonElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

    const statType = document.getElementById('stat-type') as HTMLDivElement;
    const statSize = document.getElementById('stat-size') as HTMLDivElement;
    const statKeys = document.getElementById('stat-keys') as HTMLDivElement;
    const statDepth = document.getElementById('stat-depth') as HTMLDivElement;

    let parsedJson: unknown = null;

    function showError(message: string): void {
      errorMessage.classList.remove('hidden');
      successMessage.classList.add('hidden');
      errorText.textContent = message;
      statusBadge.className = 'badge badge-error';
      statusBadge.textContent = 'Invalid';
      copyBtn.disabled = true;
    }

    function showSuccess(): void {
      errorMessage.classList.add('hidden');
      successMessage.classList.remove('hidden');
      statusBadge.className = 'badge badge-success';
      statusBadge.textContent = 'Valid';
      copyBtn.disabled = false;
    }

    function resetState(): void {
      errorMessage.classList.add('hidden');
      successMessage.classList.add('hidden');
      statusBadge.className = 'badge badge-ghost';
      statusBadge.textContent = 'Waiting for input';
      copyBtn.disabled = true;
      statType.textContent = '-';
      statSize.textContent = '-';
      statKeys.textContent = '-';
      statDepth.textContent = '-';
    }

    function getJsonType(value: unknown): string {
      if (value === null) return 'null';
      if (Array.isArray(value)) return 'array';
      return typeof value;
    }

    function countKeys(obj: unknown): number {
      if (typeof obj !== 'object' || obj === null) return 0;
      if (Array.isArray(obj)) {
        return obj.reduce((sum, item) => sum + countKeys(item), 0);
      }
      let count = Object.keys(obj).length;
      for (const value of Object.values(obj)) {
        count += countKeys(value);
      }
      return count;
    }

    function getMaxDepth(obj: unknown, currentDepth = 0): number {
      if (typeof obj !== 'object' || obj === null) return currentDepth;
      if (Array.isArray(obj)) {
        if (obj.length === 0) return currentDepth + 1;
        return Math.max(...obj.map(item => getMaxDepth(item, currentDepth + 1)));
      }
      const keys = Object.keys(obj);
      if (keys.length === 0) return currentDepth + 1;
      return Math.max(...Object.values(obj).map(value => getMaxDepth(value, currentDepth + 1)));
    }

    function updateStats(value: unknown): void {
      statType.textContent = getJsonType(value);
      
      const inputSize = new Blob([jsonInput.value]).size;
      if (inputSize < 1024) {
        statSize.textContent = `${inputSize} B`;
      } else if (inputSize < 1024 * 1024) {
        statSize.textContent = `${(inputSize / 1024).toFixed(2)} KB`;
      } else {
        statSize.textContent = `${(inputSize / (1024 * 1024)).toFixed(2)} MB`;
      }

      statKeys.textContent = countKeys(value).toString();
      statDepth.textContent = getMaxDepth(value).toString();
    }

    function validate(): boolean {
      const input = jsonInput.value.trim();
      
      if (!input) {
        resetState();
        jsonOutput.innerHTML = '<span class="text-base-content/50">Output will appear here</span>';
        return false;
      }

      try {
        parsedJson = JSON.parse(input);
        showSuccess();
        updateStats(parsedJson);
        return true;
      } catch (e) {
        const error = e as SyntaxError;
        // Try to extract line/column from error message
        const match = error.message.match(/position\s+(\d+)/i);
        if (match) {
          const position = parseInt(match[1]);
          const lines = input.substring(0, position).split('\n');
          const line = lines.length;
          const column = lines[lines.length - 1].length + 1;
          showError(`${error.message} (line ${line}, column ${column})`);
        } else {
          showError(error.message);
        }
        parsedJson = null;
        return false;
      }
    }

    function format(): void {
      if (!validate()) return;
      
      const formatted = JSON.stringify(parsedJson, null, 2);
      jsonOutput.innerHTML = syntaxHighlight(formatted);
    }

    function minify(): void {
      if (!validate()) return;
      
      const minified = JSON.stringify(parsedJson);
      jsonInput.value = minified;
      jsonOutput.textContent = minified;
    }

    function syntaxHighlight(json: string): string {
      // Escape HTML first
      json = json.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      
      // Apply syntax highlighting
      return json.replace(
        /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)/g,
        (match) => {
          let cls = 'text-orange-500'; // number
          if (/^"/.test(match)) {
            if (/:$/.test(match)) {
              cls = 'text-primary'; // key
            } else {
              cls = 'text-success'; // string
            }
          } else if (/true|false/.test(match)) {
            cls = 'text-info'; // boolean
          } else if (/null/.test(match)) {
            cls = 'text-base-content/50'; // null
          }
          return `<span class="${cls}">${match}</span>`;
        }
      );
    }

    // Event listeners
    validateBtn.addEventListener('click', validate);
    formatBtn.addEventListener('click', format);
    minifyBtn.addEventListener('click', minify);

    clearBtn.addEventListener('click', () => {
      jsonInput.value = '';
      jsonOutput.innerHTML = '<span class="text-base-content/50">Output will appear here</span>';
      resetState();
      parsedJson = null;
    });

    sampleBtn.addEventListener('click', () => {
      const sample = {
        name: "John Doe",
        age: 30,
        email: "john@example.com",
        isActive: true,
        roles: ["admin", "user"],
        preferences: {
          theme: "dark",
          notifications: {
            email: true,
            push: false
          }
        },
        lastLogin: null
      };
      jsonInput.value = JSON.stringify(sample, null, 2);
      format();
    });

    copyBtn.addEventListener('click', async () => {
      if (!parsedJson) return;
      const formatted = JSON.stringify(parsedJson, null, 2);
      await navigator.clipboard.writeText(formatted);
      copyBtn.innerHTML = `
        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
        Copied!
      `;
      setTimeout(() => {
        copyBtn.innerHTML = `
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
          </svg>
          Copy
        `;
      }, 1500);
    });

    // Auto-validate on input with debounce
    let debounceTimer: ReturnType<typeof setTimeout>;
    jsonInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        if (jsonInput.value.trim()) {
          validate();
        } else {
          resetState();
          jsonOutput.innerHTML = '<span class="text-base-content/50">Output will appear here</span>';
        }
      }, 300);
    });
  </script>
</Layout>
