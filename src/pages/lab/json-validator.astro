---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="JSON Validator - Lab Tools">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/lab" class="btn btn-ghost btn-sm mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Lab
        </a>
        <h1 class="text-3xl font-bold">JSON Validator</h1>
        <p class="text-base-content/70 mt-2">Validate, format, and debug JSON data</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Input Section -->
        <div class="space-y-6">
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <div class="flex items-center justify-between mb-4">
                <h2 class="card-title">JSON Input</h2>
                <div class="flex gap-2">
                  <button id="paste-btn" class="btn btn-sm btn-ghost">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    Paste
                  </button>
                  <button id="clear-btn" class="btn btn-sm btn-ghost">
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                    Clear
                  </button>
                </div>
              </div>
              <textarea 
                id="json-input"
                class="textarea textarea-bordered font-mono text-sm h-96 w-full"
                placeholder='{"example": "Paste your JSON here..."}'
              ></textarea>
            </div>
          </div>

          <!-- Quick Examples -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <h2 class="card-title">Quick Examples</h2>
              <div class="flex flex-wrap gap-2">
                <button class="btn btn-sm btn-ghost example-btn" data-example='{"name": "John", "age": 30, "active": true}'>Simple Object</button>
                <button class="btn btn-sm btn-ghost example-btn" data-example='[1, 2, 3, "four", true]'>Array</button>
                <button class="btn btn-sm btn-ghost example-btn" data-example='{"users": [{"id": 1, "name": "Alice"}, {"id": 2, "name": "Bob"}]}'>Nested</button>
                <button class="btn btn-sm btn-ghost example-btn" data-example='{"invalid": "missing quote}'>Invalid JSON</button>
              </div>
            </div>
          </div>
        </div>

        <!-- Results Section -->
        <div class="space-y-6">
          <!-- Status -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <div class="flex items-center justify-between">
                <h2 class="card-title">Validation Status</h2>
                <div id="status-badge" class="badge badge-ghost">Waiting for input</div>
              </div>
              <div id="error-message" class="alert alert-error hidden">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div>
                  <div id="error-title" class="font-bold"></div>
                  <div id="error-detail" class="text-sm"></div>
                </div>
              </div>
              <div id="success-message" class="alert alert-success hidden">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>Valid JSON</span>
              </div>
            </div>
          </div>

          <!-- Formatted Output -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <div class="flex items-center justify-between mb-4">
                <h2 class="card-title">Formatted Output</h2>
                <div class="flex gap-2">
                  <select id="indent-select" class="select select-sm select-bordered">
                    <option value="2">2 spaces</option>
                    <option value="4">4 spaces</option>
                    <option value="tab">Tabs</option>
                  </select>
                  <button id="copy-btn" class="btn btn-sm btn-primary" disabled>
                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                    </svg>
                    Copy
                  </button>
                </div>
              </div>
              <pre id="formatted-output" class="bg-base-200 p-4 rounded-lg overflow-auto max-h-80 font-mono text-sm"><span class="text-base-content/50">Formatted JSON will appear here...</span></pre>
            </div>
          </div>

          <!-- JSON Stats -->
          <div class="card bg-base-100 shadow-lg">
            <div class="card-body">
              <h2 class="card-title">JSON Statistics</h2>
              <div id="json-stats" class="grid grid-cols-2 gap-4">
                <div class="stat bg-base-200 rounded-lg p-3">
                  <div class="stat-title text-xs">Type</div>
                  <div id="stat-type" class="stat-value text-lg">-</div>
                </div>
                <div class="stat bg-base-200 rounded-lg p-3">
                  <div class="stat-title text-xs">Size</div>
                  <div id="stat-size" class="stat-value text-lg">-</div>
                </div>
                <div class="stat bg-base-200 rounded-lg p-3">
                  <div class="stat-title text-xs">Keys</div>
                  <div id="stat-keys" class="stat-value text-lg">-</div>
                </div>
                <div class="stat bg-base-200 rounded-lg p-3">
                  <div class="stat-title text-xs">Depth</div>
                  <div id="stat-depth" class="stat-value text-lg">-</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
    const statusBadge = document.getElementById('status-badge') as HTMLDivElement;
    const errorMessage = document.getElementById('error-message') as HTMLDivElement;
    const errorTitle = document.getElementById('error-title') as HTMLDivElement;
    const errorDetail = document.getElementById('error-detail') as HTMLDivElement;
    const successMessage = document.getElementById('success-message') as HTMLDivElement;
    const formattedOutput = document.getElementById('formatted-output') as HTMLPreElement;
    const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const pasteBtn = document.getElementById('paste-btn') as HTMLButtonElement;
    const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
    const statType = document.getElementById('stat-type') as HTMLDivElement;
    const statSize = document.getElementById('stat-size') as HTMLDivElement;
    const statKeys = document.getElementById('stat-keys') as HTMLDivElement;
    const statDepth = document.getElementById('stat-depth') as HTMLDivElement;

    let parsedJson: unknown = null;

    function getIndent(): string | number {
      const value = indentSelect.value;
      return value === 'tab' ? '\t' : parseInt(value);
    }

    function formatBytes(bytes: number): string {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
    }

    function getJsonType(value: unknown): string {
      if (value === null) return 'null';
      if (Array.isArray(value)) return 'array';
      return typeof value;
    }

    function countKeys(obj: unknown, depth: number = 0): { keys: number; maxDepth: number } {
      if (typeof obj !== 'object' || obj === null) {
        return { keys: 0, maxDepth: depth };
      }

      let keys = 0;
      let maxDepth = depth;

      if (Array.isArray(obj)) {
        for (const item of obj) {
          const result = countKeys(item, depth + 1);
          keys += result.keys;
          maxDepth = Math.max(maxDepth, result.maxDepth);
        }
      } else {
        keys = Object.keys(obj).length;
        for (const value of Object.values(obj)) {
          const result = countKeys(value, depth + 1);
          keys += result.keys;
          maxDepth = Math.max(maxDepth, result.maxDepth);
        }
      }

      return { keys, maxDepth };
    }

    function validateJson() {
      const input = jsonInput.value.trim();

      if (!input) {
        statusBadge.className = 'badge badge-ghost';
        statusBadge.textContent = 'Waiting for input';
        errorMessage.classList.add('hidden');
        successMessage.classList.add('hidden');
        formattedOutput.innerHTML = '<span class="text-base-content/50">Formatted JSON will appear here...</span>';
        copyBtn.disabled = true;
        statType.textContent = '-';
        statSize.textContent = '-';
        statKeys.textContent = '-';
        statDepth.textContent = '-';
        parsedJson = null;
        return;
      }

      try {
        parsedJson = JSON.parse(input);
        
        statusBadge.className = 'badge badge-success';
        statusBadge.textContent = 'Valid';
        errorMessage.classList.add('hidden');
        successMessage.classList.remove('hidden');

        // Format output
        const indent = getIndent();
        const formatted = JSON.stringify(parsedJson, null, indent);
        formattedOutput.textContent = formatted;
        copyBtn.disabled = false;

        // Calculate stats
        const size = new Blob([input]).size;
        const { keys, maxDepth } = countKeys(parsedJson);

        statType.textContent = getJsonType(parsedJson);
        statSize.textContent = formatBytes(size);
        statKeys.textContent = keys.toString();
        statDepth.textContent = maxDepth.toString();

      } catch (e) {
        const error = e as SyntaxError;
        parsedJson = null;

        statusBadge.className = 'badge badge-error';
        statusBadge.textContent = 'Invalid';
        successMessage.classList.add('hidden');
        errorMessage.classList.remove('hidden');

        // Parse error message for position
        const match = error.message.match(/position (\d+)/i);
        if (match) {
          const pos = parseInt(match[1]);
          errorTitle.textContent = 'Parse Error';
          errorDetail.textContent = `${error.message}\nNear: "...${input.substring(Math.max(0, pos - 20), pos)}►${input.substring(pos, pos + 20)}..."`;
        } else {
          errorTitle.textContent = 'Parse Error';
          errorDetail.textContent = error.message;
        }

        formattedOutput.innerHTML = '<span class="text-base-content/50">Fix JSON errors to see formatted output</span>';
        copyBtn.disabled = true;

        statType.textContent = '-';
        statSize.textContent = formatBytes(new Blob([input]).size);
        statKeys.textContent = '-';
        statDepth.textContent = '-';
      }
    }

    // Event listeners
    jsonInput.addEventListener('input', validateJson);
    indentSelect.addEventListener('change', () => {
      if (parsedJson !== null) {
        const indent = getIndent();
        formattedOutput.textContent = JSON.stringify(parsedJson, null, indent);
      }
    });

    copyBtn.addEventListener('click', async () => {
      if (formattedOutput.textContent) {
        await navigator.clipboard.writeText(formattedOutput.textContent);
        copyBtn.innerHTML = `
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Copied!
        `;
        setTimeout(() => {
          copyBtn.innerHTML = `
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
            Copy
          `;
        }, 1500);
      }
    });

    pasteBtn.addEventListener('click', async () => {
      const text = await navigator.clipboard.readText();
      jsonInput.value = text;
      validateJson();
    });

    clearBtn.addEventListener('click', () => {
      jsonInput.value = '';
      validateJson();
    });

    // Example buttons
    document.querySelectorAll('.example-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        jsonInput.value = (btn as HTMLElement).dataset.example!;
        validateJson();
      });
    });
  </script>
</Layout>
