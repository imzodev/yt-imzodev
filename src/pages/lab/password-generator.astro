---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Password Generator - Lab Tools">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/lab" class="btn btn-ghost btn-sm mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Lab
        </a>
        <h1 class="text-3xl font-bold">Password Generator</h1>
        <p class="text-base-content/70 mt-2">Generate secure passwords with customizable options</p>
      </div>

      <!-- Password Display -->
      <div class="card bg-base-100 shadow-lg mb-6">
        <div class="card-body">
          <div class="flex items-center gap-4">
            <div class="flex-1 bg-base-200 rounded-lg p-4 font-mono text-xl break-all" id="password-display">
              Click "Generate" to create a password
            </div>
            <div class="flex flex-col gap-2">
              <button id="copy-btn" class="btn btn-primary" disabled>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                </svg>
                Copy
              </button>
              <button id="generate-btn" class="btn btn-secondary">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                Generate
              </button>
            </div>
          </div>

          <!-- Strength Indicator -->
          <div class="mt-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-medium">Password Strength</span>
              <span id="strength-label" class="text-sm font-medium">-</span>
            </div>
            <progress id="strength-bar" class="progress progress-primary w-full" value="0" max="100"></progress>
          </div>
        </div>
      </div>

      <!-- Options -->
      <div class="card bg-base-100 shadow-lg mb-6">
        <div class="card-body">
          <h2 class="card-title mb-4">Password Options</h2>

          <!-- Length Slider -->
          <div class="form-control mb-6">
            <div class="flex items-center justify-between mb-2">
              <label class="label">
                <span class="label-text font-medium">Password Length</span>
              </label>
              <span id="length-value" class="text-lg font-bold">16</span>
            </div>
            <input 
              type="range" 
              id="length-slider" 
              min="8" 
              max="64" 
              value="16" 
              class="range range-primary"
            />
            <div class="flex justify-between text-xs text-base-content/50 mt-1">
              <span>8</span>
              <span>24</span>
              <span>40</span>
              <span>64</span>
            </div>
          </div>

          <!-- Character Options -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="uppercase" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-medium">Uppercase (A-Z)</span>
                <div class="text-xs text-base-content/50">Include capital letters</div>
              </div>
            </label>

            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="lowercase" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-medium">Lowercase (a-z)</span>
                <div class="text-xs text-base-content/50">Include small letters</div>
              </div>
            </label>

            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="numbers" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-medium">Numbers (0-9)</span>
                <div class="text-xs text-base-content/50">Include digits</div>
              </div>
            </label>

            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="symbols" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-medium">Symbols (!@#$%)</span>
                <div class="text-xs text-base-content/50">Include special characters</div>
              </div>
            </label>
          </div>

          <!-- Exclude Characters -->
          <div class="form-control mt-6">
            <label class="label">
              <span class="label-text font-medium">Exclude Characters</span>
            </label>
            <input 
              type="text" 
              id="exclude-chars" 
              class="input input-bordered w-full"
              placeholder="e.g., 0O1lI"
            />
            <label class="label">
              <span class="label-text-alt text-base-content/50">Characters to exclude from the password</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Password History -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <div class="flex items-center justify-between mb-4">
            <h2 class="card-title">Recent Passwords</h2>
            <button id="clear-history-btn" class="btn btn-sm btn-ghost">Clear</button>
          </div>
          <div id="password-history" class="space-y-2">
            <p class="text-base-content/50 text-sm">Generated passwords will appear here</p>
          </div>
        </div>
      </div>

      <!-- Security Note -->
      <div class="alert mt-6">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        <div>
          <h3 class="font-bold">Security Note</h3>
          <div class="text-sm">Passwords are generated entirely in your browser. Nothing is sent to any server.</div>
        </div>
      </div>
    </div>
  </main>

  <script>
    const passwordDisplay = document.getElementById('password-display') as HTMLDivElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
    const strengthBar = document.getElementById('strength-bar') as HTMLProgressElement;
    const strengthLabel = document.getElementById('strength-label') as HTMLSpanElement;
    const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
    const lengthValue = document.getElementById('length-value') as HTMLSpanElement;
    const uppercaseCheck = document.getElementById('uppercase') as HTMLInputElement;
    const lowercaseCheck = document.getElementById('lowercase') as HTMLInputElement;
    const numbersCheck = document.getElementById('numbers') as HTMLInputElement;
    const symbolsCheck = document.getElementById('symbols') as HTMLInputElement;
    const excludeChars = document.getElementById('exclude-chars') as HTMLInputElement;
    const passwordHistory = document.getElementById('password-history') as HTMLDivElement;
    const clearHistoryBtn = document.getElementById('clear-history-btn') as HTMLButtonElement;

    const UPPERCASE = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const LOWERCASE = 'abcdefghijklmnopqrstuvwxyz';
    const NUMBERS = '0123456789';
    const SYMBOLS = '!@#$%^&*()_+-=[]{}|;:,.<>?';

    interface PasswordRecord {
      password: string;
      length: number;
      timestamp: Date;
    }

    let history: PasswordRecord[] = [];

    function getCharacterSet(): string {
      let chars = '';
      if (uppercaseCheck.checked) chars += UPPERCASE;
      if (lowercaseCheck.checked) chars += LOWERCASE;
      if (numbersCheck.checked) chars += NUMBERS;
      if (symbolsCheck.checked) chars += SYMBOLS;
      
      // Remove excluded characters
      const exclude = excludeChars.value;
      if (exclude) {
        chars = chars.split('').filter(c => !exclude.includes(c)).join('');
      }
      
      return chars;
    }

    function generatePassword(): string {
      const chars = getCharacterSet();
      const length = parseInt(lengthSlider.value);

      if (chars.length === 0) {
        return 'Please select at least one character type';
      }

      // Use crypto.getRandomValues for secure random generation
      const array = new Uint32Array(length);
      crypto.getRandomValues(array);
      
      let password = '';
      for (let i = 0; i < length; i++) {
        password += chars[array[i] % chars.length];
      }

      return password;
    }

    function calculateStrength(password: string): { score: number; label: string; color: string } {
      let score = 0;
      
      // Length score
      if (password.length >= 8) score += 20;
      if (password.length >= 12) score += 10;
      if (password.length >= 16) score += 10;
      if (password.length >= 24) score += 10;

      // Character variety
      if (/[a-z]/.test(password)) score += 10;
      if (/[A-Z]/.test(password)) score += 10;
      if (/[0-9]/.test(password)) score += 10;
      if (/[^a-zA-Z0-9]/.test(password)) score += 20;

      // Entropy bonus
      const uniqueChars = new Set(password).size;
      score += Math.min(uniqueChars * 2, 20);

      if (score < 40) return { score, label: 'Weak', color: 'error' };
      if (score < 60) return { score, label: 'Fair', color: 'warning' };
      if (score < 80) return { score, label: 'Good', color: 'info' };
      return { score: Math.min(score, 100), label: 'Strong', color: 'success' };
    }

    function updateStrengthIndicator(password: string): void {
      const { score, label, color } = calculateStrength(password);
      strengthBar.value = score;
      strengthBar.className = `progress progress-${color} w-full`;
      strengthLabel.textContent = label;
      strengthLabel.className = `text-sm font-medium text-${color}`;
    }

    function addToHistory(password: string): void {
      const record: PasswordRecord = {
        password,
        length: password.length,
        timestamp: new Date()
      };
      
      history.unshift(record);
      if (history.length > 5) history.pop();
      
      renderHistory();
    }

    function renderHistory(): void {
      if (history.length === 0) {
        passwordHistory.innerHTML = '<p class="text-base-content/50 text-sm">Generated passwords will appear here</p>';
        return;
      }

      passwordHistory.innerHTML = history.map((record, index) => `
        <div class="flex items-center gap-2 p-2 bg-base-200 rounded">
          <code class="font-mono text-sm flex-1 truncate">${escapeHtml(record.password)}</code>
          <span class="text-xs text-base-content/50">${record.length} chars</span>
          <button class="btn btn-xs btn-ghost copy-history" data-password="${escapeHtml(record.password)}">Copy</button>
        </div>
      `).join('');
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function handleGenerate(): void {
      const password = generatePassword();
      passwordDisplay.textContent = password;
      copyBtn.disabled = password === 'Please select at least one character type';
      updateStrengthIndicator(password);
      
      if (copyBtn.disabled === false) {
        addToHistory(password);
      }
    }

    // Event listeners
    generateBtn.addEventListener('click', handleGenerate);

    lengthSlider.addEventListener('input', () => {
      lengthValue.textContent = lengthSlider.value;
    });

    copyBtn.addEventListener('click', async () => {
      const password = passwordDisplay.textContent;
      if (password) {
        await navigator.clipboard.writeText(password);
        copyBtn.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Copied!
        `;
        setTimeout(() => {
          copyBtn.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
            </svg>
            Copy
          `;
        }, 1500);
      }
    });

    passwordHistory.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('copy-history')) {
        const password = target.dataset.password!;
        await navigator.clipboard.writeText(password);
        target.textContent = 'Copied!';
        setTimeout(() => target.textContent = 'Copy', 1500);
      }
    });

    clearHistoryBtn.addEventListener('click', () => {
      history = [];
      renderHistory();
    });

    // Auto-generate on option change
    [uppercaseCheck, lowercaseCheck, numbersCheck, symbolsCheck].forEach(checkbox => {
      checkbox.addEventListener('change', () => {
        // Ensure at least one is checked
        const checked = [uppercaseCheck, lowercaseCheck, numbersCheck, symbolsCheck].filter(c => c.checked);
        if (checked.length === 0) {
          checkbox.checked = true;
        }
      });
    });

    // Generate initial password
    handleGenerate();
  </script>
</Layout>
