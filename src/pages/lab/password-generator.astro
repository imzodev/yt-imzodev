---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
---

<Layout title="Password Generator - Lab Tools">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/lab" class="btn btn-ghost btn-sm mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Lab
        </a>
        <h1 class="text-3xl font-bold">Password Generator</h1>
        <p class="text-base-content/70 mt-2">Generate secure passwords with customizable options</p>
      </div>

      <!-- Generated Password -->
      <div class="card bg-base-100 shadow-lg mb-6">
        <div class="card-body">
          <h2 class="card-title">Generated Password</h2>
          <div class="flex gap-2">
            <input 
              type="text" 
              id="password-output"
              class="input input-bordered flex-1 font-mono text-lg"
              readonly
              placeholder="Click Generate..."
            />
            <button id="copy-btn" class="btn btn-primary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
              </svg>
              Copy
            </button>
            <button id="regenerate-btn" class="btn btn-secondary">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              Generate
            </button>
          </div>
          
          <!-- Password Strength -->
          <div class="mt-4">
            <div class="flex justify-between mb-1">
              <span class="text-sm">Strength</span>
              <span id="strength-label" class="text-sm font-semibold">-</span>
            </div>
            <progress id="strength-bar" class="progress progress-primary w-full" value="0" max="100"></progress>
          </div>
          
          <!-- Entropy Info -->
          <div class="flex gap-4 mt-2 text-sm text-base-content/70">
            <span>Length: <strong id="actual-length">0</strong></span>
            <span>Entropy: <strong id="entropy-bits">0</strong> bits</span>
            <span>Pool: <strong id="pool-size">0</strong> chars</span>
          </div>
        </div>
      </div>

      <!-- Options -->
      <div class="card bg-base-100 shadow-lg mb-6">
        <div class="card-body">
          <h2 class="card-title">Options</h2>
          
          <!-- Length Slider -->
          <div class="form-control">
            <label class="label">
              <span class="label-text font-semibold">Password Length</span>
              <span id="length-value" class="label-text-alt font-mono">16</span>
            </label>
            <input 
              type="range" 
              id="length-slider"
              class="range range-primary"
              min="8"
              max="64"
              value="16"
            />
            <div class="flex justify-between text-xs text-base-content/50 mt-1">
              <span>8</span>
              <span>16</span>
              <span>24</span>
              <span>32</span>
              <span>48</span>
              <span>64</span>
            </div>
          </div>

          <!-- Character Options -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="opt-uppercase" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-semibold">Uppercase (A-Z)</span>
                <div class="text-xs text-base-content/50">ABCDEF...</div>
              </div>
            </label>
            
            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="opt-lowercase" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-semibold">Lowercase (a-z)</span>
                <div class="text-xs text-base-content/50">abcdef...</div>
              </div>
            </label>
            
            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="opt-numbers" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-semibold">Numbers (0-9)</span>
                <div class="text-xs text-base-content/50">0123456789</div>
              </div>
            </label>
            
            <label class="label cursor-pointer justify-start gap-4 p-4 bg-base-200 rounded-lg">
              <input type="checkbox" id="opt-symbols" class="checkbox checkbox-primary" checked />
              <div>
                <span class="label-text font-semibold">Symbols</span>
                <div class="text-xs text-base-content/50">!@#$%^&*()_+-=[]{}|;:,.&lt;&gt;?</div>
              </div>
            </label>
          </div>

          <!-- Exclude Ambiguous -->
          <div class="mt-4">
            <label class="label cursor-pointer justify-start gap-4">
              <input type="checkbox" id="opt-exclude-ambiguous" class="checkbox checkbox-sm" />
              <div>
                <span class="label-text">Exclude ambiguous characters</span>
                <div class="text-xs text-base-content/50">0, O, l, 1, I, |, etc.</div>
              </div>
            </label>
          </div>
        </div>
      </div>

      <!-- Quick Presets -->
      <div class="card bg-base-100 shadow-lg mb-6">
        <div class="card-body">
          <h2 class="card-title">Quick Presets</h2>
          <div class="flex flex-wrap gap-2">
            <button class="btn btn-sm btn-ghost preset-btn" data-length="12" data-upper="true" data-lower="true" data-numbers="true" data-symbols="false">Simple (12)</button>
            <button class="btn btn-sm btn-ghost preset-btn" data-length="16" data-upper="true" data-lower="true" data-numbers="true" data-symbols="true">Standard (16)</button>
            <button class="btn btn-sm btn-ghost preset-btn" data-length="24" data-upper="true" data-lower="true" data-numbers="true" data-symbols="true">Strong (24)</button>
            <button class="btn btn-sm btn-ghost preset-btn" data-length="32" data-upper="true" data-lower="true" data-numbers="true" data-symbols="true">Maximum (32)</button>
            <button class="btn btn-sm btn-ghost preset-btn" data-length="8" data-upper="false" data-lower="true" data-numbers="true" data-symbols="false">PIN-like (8)</button>
            <button class="btn btn-sm btn-ghost preset-btn" data-length="20" data-upper="true" data-lower="true" data-numbers="false" data-symbols="false">Alphabetic (20)</button>
          </div>
        </div>
      </div>

      <!-- Password History -->
      <div class="card bg-base-100 shadow-lg">
        <div class="card-body">
          <div class="flex items-center justify-between">
            <h2 class="card-title">Recent Passwords</h2>
            <button id="clear-history-btn" class="btn btn-sm btn-ghost">Clear</button>
          </div>
          <div id="password-history" class="space-y-2">
            <p class="text-base-content/50 text-sm">Generated passwords will appear here</p>
          </div>
          <p class="text-xs text-base-content/50 mt-2">
            ⚠️ Passwords are stored temporarily in browser memory only
          </p>
        </div>
      </div>
    </div>
  </main>

  <script>
    const passwordOutput = document.getElementById('password-output') as HTMLInputElement;
    const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
    const regenerateBtn = document.getElementById('regenerate-btn') as HTMLButtonElement;
    const lengthSlider = document.getElementById('length-slider') as HTMLInputElement;
    const lengthValue = document.getElementById('length-value') as HTMLSpanElement;
    const strengthBar = document.getElementById('strength-bar') as HTMLProgressElement;
    const strengthLabel = document.getElementById('strength-label') as HTMLSpanElement;
    const actualLength = document.getElementById('actual-length') as HTMLSpanElement;
    const entropyBits = document.getElementById('entropy-bits') as HTMLSpanElement;
    const poolSize = document.getElementById('pool-size') as HTMLSpanElement;
    const passwordHistory = document.getElementById('password-history') as HTMLDivElement;
    const clearHistoryBtn = document.getElementById('clear-history-btn') as HTMLButtonElement;

    const optUppercase = document.getElementById('opt-uppercase') as HTMLInputElement;
    const optLowercase = document.getElementById('opt-lowercase') as HTMLInputElement;
    const optNumbers = document.getElementById('opt-numbers') as HTMLInputElement;
    const optSymbols = document.getElementById('opt-symbols') as HTMLInputElement;
    const optExcludeAmbiguous = document.getElementById('opt-exclude-ambiguous') as HTMLInputElement;

    const CHAR_SETS = {
      uppercase: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lowercase: 'abcdefghijklmnopqrstuvwxyz',
      numbers: '0123456789',
      symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?'
    };

    const AMBIGUOUS_CHARS = ['0', 'O', 'l', '1', 'I', '|', '`', "'", '"'];

    let history: string[] = [];

    function getCharacterSet(): string {
      let chars = '';
      if (optUppercase.checked) chars += CHAR_SETS.uppercase;
      if (optLowercase.checked) chars += CHAR_SETS.lowercase;
      if (optNumbers.checked) chars += CHAR_SETS.numbers;
      if (optSymbols.checked) chars += CHAR_SETS.symbols;

      if (optExcludeAmbiguous.checked) {
        chars = chars.split('').filter(c => !AMBIGUOUS_CHARS.includes(c)).join('');
      }

      return chars;
    }

    function generatePassword(): string {
      const chars = getCharacterSet();
      const length = parseInt(lengthSlider.value);

      if (chars.length === 0) {
        return 'Select at least one character type';
      }

      // Use crypto.getRandomValues for cryptographically secure randomness
      const array = new Uint32Array(length);
      crypto.getRandomValues(array);
      
      let password = '';
      for (let i = 0; i < length; i++) {
        password += chars[array[i] % chars.length];
      }

      return password;
    }

    function calculateEntropy(password: string, poolSize: number): number {
      if (poolSize === 0) return 0;
      return Math.round(password.length * Math.log2(poolSize) * 10) / 10;
    }

    function getStrengthInfo(entropy: number): { label: string; value: number; class: string } {
      if (entropy < 28) return { label: 'Very Weak', value: 20, class: 'progress-error' };
      if (entropy < 36) return { label: 'Weak', value: 40, class: 'progress-warning' };
      if (entropy < 60) return { label: 'Fair', value: 60, class: 'progress-info' };
      if (entropy < 80) return { label: 'Strong', value: 80, class: 'progress-success' };
      return { label: 'Very Strong', value: 100, class: 'progress-success' };
    }

    function updateDisplay(password: string): void {
      passwordOutput.value = password;
      const chars = getCharacterSet();
      const entropy = calculateEntropy(password, chars.length);
      const strength = getStrengthInfo(entropy);

      actualLength.textContent = password.length.toString();
      entropyBits.textContent = entropy.toFixed(1);
      poolSize.textContent = chars.length.toString();
      
      strengthBar.value = strength.value;
      strengthBar.className = `progress ${strength.class} w-full`;
      strengthLabel.textContent = strength.label;
    }

    function addToHistory(password: string): void {
      history.unshift(password);
      if (history.length > 5) history.pop();
      renderHistory();
    }

    function renderHistory(): void {
      if (history.length === 0) {
        passwordHistory.innerHTML = '<p class="text-base-content/50 text-sm">Generated passwords will appear here</p>';
        return;
      }

      passwordHistory.innerHTML = history.map((pw, i) => `
        <div class="flex items-center gap-2 p-2 bg-base-200 rounded">
          <span class="text-xs text-base-content/50 w-6">${i + 1}</span>
          <code class="font-mono text-sm flex-1 truncate">${escapeHtml(pw)}</code>
          <button class="btn btn-xs btn-ghost copy-history-btn" data-password="${escapeHtml(pw)}">Copy</button>
        </div>
      `).join('');
    }

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function generate(): void {
      const password = generatePassword();
      updateDisplay(password);
      if (!password.includes('Select')) {
        addToHistory(password);
      }
    }

    // Event listeners
    regenerateBtn.addEventListener('click', generate);
    copyBtn.addEventListener('click', async () => {
      const password = passwordOutput.value;
      if (password && !password.includes('Select')) {
        await navigator.clipboard.writeText(password);
        copyBtn.innerHTML = `
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Copied!
        `;
        setTimeout(() => {
          copyBtn.innerHTML = `
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            Copy
          `;
        }, 1500);
      }
    });

    lengthSlider.addEventListener('input', () => {
      lengthValue.textContent = lengthSlider.value;
      generate();
    });

    [optUppercase, optLowercase, optNumbers, optSymbols, optExcludeAmbiguous].forEach(el => {
      el.addEventListener('change', generate);
    });

    clearHistoryBtn.addEventListener('click', () => {
      history = [];
      renderHistory();
    });

    // History copy buttons
    passwordHistory.addEventListener('click', async (e) => {
      const target = e.target as HTMLElement;
      if (target.classList.contains('copy-history-btn')) {
        const password = target.dataset.password!;
        await navigator.clipboard.writeText(password);
        target.textContent = 'Copied!';
        setTimeout(() => target.textContent = 'Copy', 1500);
      }
    });

    // Presets
    document.querySelectorAll('.preset-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        lengthSlider.value = el.dataset.length!;
        lengthValue.textContent = el.dataset.length!;
        optUppercase.checked = el.dataset.upper === 'true';
        optLowercase.checked = el.dataset.lower === 'true';
        optNumbers.checked = el.dataset.numbers === 'true';
        optSymbols.checked = el.dataset.symbols === 'true';
        generate();
      });
    });

    // Generate initial password
    generate();
  </script>
</Layout>
