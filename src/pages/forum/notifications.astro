---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Alert from '../../components/ui/Alert.astro';
import { getSession } from '../../lib/server/auth';

import { getForumNotifications, getNotificationPreferences, getViewerBySupabaseId } from '../../lib/server/forum';

export const prerender = false;

const authResult = await getSession(Astro, { requireAuth: true });
if (authResult instanceof Response) return authResult;
const { user } = authResult;
const viewer = await getViewerBySupabaseId(user?.id);

if (!viewer) {
  return Astro.redirect('/login');
}let feedbackMessage = Astro.url.searchParams.get('message') || '';
let feedbackType = (Astro.url.searchParams.get('type') as 'success' | 'error' | null) || null;

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  if (!validateCsrfToken(Astro.cookies, formData.get('csrf_token') as string | null)) {
    const redirectUrl = new URL(Astro.request.url);
    redirectUrl.searchParams.set('type', 'error');
    redirectUrl.searchParams.set('message', 'Invalid request. Please try again.');
    return Astro.redirect(`${redirectUrl.pathname}${redirectUrl.search}`);
  }

  try {
    const forumActions = await import('../../lib/server/forum-actions');

    return Astro.redirect(await forumActions.handleForumNotificationsAction({
      formData,
      viewerId: viewer.id,
      requestUrl: Astro.url,
    }));
  } catch (error) {
    feedbackType = 'error';
    feedbackMessage = error instanceof Error ? error.message : 'Something went wrong.';
  }
}

const [notifications, preferences] = await Promise.all([
  getForumNotifications(viewer.id),
  getNotificationPreferences(viewer.id),
]);
---

<Layout title="Forum Notifications - YouTube Community Portal">
  <Navbar />
  <main class="min-h-screen bg-base-200 px-4 py-10 mt-16">
    <div class="mx-auto flex max-w-5xl flex-col gap-6">
      <section class="card bg-base-100 shadow-xl">
        <div class="card-body gap-4 md:flex-row md:items-center md:justify-between">
          <div>
            <div class="badge badge-secondary badge-outline">Simple notifications</div>
            <h1 class="mt-3 text-3xl font-black text-base-content">Your forum inbox</h1>
            <p class="mt-2 max-w-2xl text-base-content/70">Notifications are stored in-app and refresh on each request. No realtime sockets are used in this phase.</p>
          </div>
          <div class="flex gap-3">
            <a href="/forum" class="btn btn-outline">Back to forum</a>
            <form method="POST">
              <button type="submit" class="btn btn-primary">Mark all as read</button>
            </form>
          </div>
        </div>
      </section>

      {feedbackMessage && feedbackType && (
        <Alert type={feedbackType} message={feedbackMessage} />
      )}

      <!-- Notification Preferences -->
      <section class="card bg-base-100 shadow-lg">
        <div class="card-body gap-5">
          <div class="flex items-center justify-between">
            <h2 class="card-title text-2xl">Notification Preferences</h2>
            <span class="badge badge-ghost">Configure what you want to be notified about</span>
          </div>

          <form method="POST" class="space-y-4">
            <input type="hidden" name="intent" value="update-preferences" />
            
            <div class="grid gap-4 md:grid-cols-2">
              <label class="flex cursor-pointer items-center gap-4 rounded-2xl border border-base-300 p-4 transition hover:border-primary">
                <input 
                  type="checkbox" 
                  name="reply_notifications" 
                  class="checkbox checkbox-primary" 
                  checked={preferences?.replyNotifications ?? true}
                />
                <div>
                  <h3 class="font-semibold text-base-content">Reply Notifications</h3>
                  <p class="text-sm text-base-content/70">Get notified when someone replies to your threads</p>
                </div>
              </label>

              <label class="flex cursor-pointer items-center gap-4 rounded-2xl border border-base-300 p-4 transition hover:border-primary">
                <input 
                  type="checkbox" 
                  name="follow_notifications" 
                  class="checkbox checkbox-primary" 
                  checked={preferences?.followNotifications ?? true}
                />
                <div>
                  <h3 class="font-semibold text-base-content">Follow Notifications</h3>
                  <p class="text-sm text-base-content/70">Get notified when someone follows you</p>
                </div>
              </label>

              <label class="flex cursor-pointer items-center gap-4 rounded-2xl border border-base-300 p-4 transition hover:border-primary">
                <input 
                  type="checkbox" 
                  name="best_answer_notifications" 
                  class="checkbox checkbox-primary" 
                  checked={preferences?.bestAnswerNotifications ?? true}
                />
                <div>
                  <h3 class="font-semibold text-base-content">Best Answer Notifications</h3>
                  <p class="text-sm text-base-content/70">Get notified when your reply is marked as best answer</p>
                </div>
              </label>

              <label class="flex cursor-pointer items-center gap-4 rounded-2xl border border-base-300 p-4 transition hover:border-primary">
                <input 
                  type="checkbox" 
                  name="report_notifications" 
                  class="checkbox checkbox-primary" 
                  checked={preferences?.reportNotifications ?? true}
                />
                <div>
                  <h3 class="font-semibold text-base-content">Report Notifications</h3>
                  <p class="text-sm text-base-content/70">Get notified about moderation reports (moderators only)</p>
                </div>
              </label>
            </div>

            <div class="flex justify-end">
              <button type="submit" class="btn btn-secondary">Save Preferences</button>
            </div>
          </form>
        </div>
      </section>

      <section class="card bg-base-100 shadow-lg">
        <div class="card-body gap-5">
          <div class="flex items-center justify-between">
            <h2 class="card-title text-2xl">Recent notifications</h2>
            <span class="badge badge-ghost">{notifications.length} total</span>
          </div>

          {notifications.length > 0 ? (
            <form method="POST" class="space-y-4">
              {notifications.map(({ notification, actor }) => (
                <label class={`flex cursor-pointer items-start gap-4 rounded-3xl border p-4 transition hover:border-primary ${notification.isRead ? 'border-base-300 bg-base-100' : 'border-secondary/30 bg-secondary/5'}`}>
                  <input type="checkbox" name="notification_id" value={notification.id} class="checkbox checkbox-sm mt-1" />
                  <div class="flex-1 space-y-2">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class={`badge ${notification.isRead ? 'badge-outline' : 'badge-secondary'}`}>{notification.type.replaceAll('_', ' ')}</span>
                      {!notification.isRead && <span class="badge badge-accent badge-outline">Unread</span>}
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold text-base-content">{notification.title}</h3>
                      <p class="text-sm text-base-content/70">{notification.message}</p>
                    </div>
                    <div class="flex flex-wrap items-center gap-3 text-xs text-base-content/50">
                      <span>{actor?.name || actor?.username || 'Community member'}</span>
                      <span>{notification.createdAt ? new Date(notification.createdAt).toLocaleString() : 'Recently'}</span>
                      {notification.postId && <a href={`/forum/thread/${notification.postId}`} class="link link-hover">Open thread</a>}
                    </div>
                  </div>
                </label>
              ))}

              <div class="flex justify-end">
                <button type="submit" class="btn btn-secondary">Mark selected as read</button>
              </div>
            </form>
          ) : (
            <div class="rounded-3xl border border-dashed border-base-300 p-10 text-center">
              <h3 class="text-xl font-semibold text-base-content">Nothing here yet</h3>
              <p class="mt-2 text-base-content/70">When someone replies to your thread, follows you, or your reply becomes the best answer, it will show up here.</p>
            </div>
          )}
        </div>
      </section>
    </div>
  </main>
</Layout>
