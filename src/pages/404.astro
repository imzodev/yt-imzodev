---
/**
 * 404 Not Found Page
 * Branded error page for missing content and invalid routes.
 */
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
---

<Layout title="404 - Page Not Found" description="The page you're looking for doesn't exist or has been moved." noindex={true}>
  <Navbar />
  
  <main class="min-h-screen bg-base-100 text-base-content flex items-center justify-center pt-16">
    <div class="text-center max-w-md mx-auto px-4 py-12">
      <!-- 404 number -->
      <h1 class="text-9xl font-bold text-primary/20">404</h1>
      
      <!-- Error message -->
      <h2 class="text-2xl font-semibold mt-4">Page Not Found</h2>
      <p class="text-base-content/60 mt-2">
        The page you're looking for doesn't exist or has been moved.
      </p>
      
      <!-- Navigation links -->
      <div class="flex flex-wrap gap-3 justify-center mt-8">
        <a href="/" class="btn btn-primary">Go Home</a>
        <a href="/blog" class="btn btn-outline">Blog</a>
        <a href="/videos" class="btn btn-outline">Videos</a>
        <a href="/snippets" class="btn btn-outline">Snippets</a>
        <a href="/forum" class="btn btn-ghost">Forum</a>
        <a href="/search" class="btn btn-ghost">Search</a>
      </div>
      
      <!-- Helpful tip -->
      <p class="text-sm text-base-content/40 mt-8">
        If you believe this is an error, please <a href="/forum" class="link link-primary">let us know</a>.
      </p>
    </div>
  </main>
</Layout>
