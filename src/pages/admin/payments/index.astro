---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import { getSession, isAdmin } from '../../../lib/server/auth';
import { getCsrfToken } from '../../../lib/server/csrf';
import { listFailedPayments } from '../../../lib/server/admin';

export const prerender = false;

// Check if user is authenticated
const authResult = await getSession(Astro);
const user = authResult?.user;

if (!user) {
  return Astro.redirect('/login?redirect=/admin/payments');
}

// Check admin role
const userIsAdmin = await isAdmin(user.id);
if (!userIsAdmin) {
  return Astro.redirect('/dashboard?error=unauthorized');
}

// Get failed payments
const failedPayments = await listFailedPayments({ limit: 100 });
const csrfToken = getCsrfToken(Astro.cookies);
---

<Layout title="Failed Payments - Admin Dashboard">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/admin" class="btn btn-ghost btn-sm mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl font-bold">Failed Payments</h1>
        <p class="text-base-content/70 mt-2">Handle failed payment attempts and dunning</p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div class="bg-base-100 shadow rounded-lg p-6">
          <div class="text-sm text-base-content/70">Total Failed</div>
          <div class="text-3xl font-bold text-error">{failedPayments.length}</div>
        </div>
        <div class="bg-base-100 shadow rounded-lg p-6">
          <div class="text-sm text-base-content/70">Total Amount</div>
          <div class="text-3xl font-bold text-warning">
            ${failedPayments.reduce((sum, { payment }) => sum + (payment.amount / 100), 0).toFixed(2)}
          </div>
        </div>
        <div class="bg-base-100 shadow rounded-lg p-6">
          <div class="text-sm text-base-content/70">Pending Resolution</div>
          <div class="text-3xl font-bold">{failedPayments.length}</div>
        </div>
      </div>

      <!-- Failed Payments Table -->
      <div class="bg-base-100 shadow rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th>User</th>
                <th>Amount</th>
                <th>Currency</th>
                <th>Description</th>
                <th>Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {failedPayments.map(({ payment, user }) => (
                <tr>
                  <td>
                    <div class="flex items-center gap-3">
                      <div class="avatar placeholder">
                        <div class="bg-neutral text-neutral-content rounded-full w-10">
                          <span class="text-sm">{user?.name?.charAt(0) || user?.email?.charAt(0).toUpperCase() || '?'}</span>
                        </div>
                      </div>
                      <div>
                        <div class="font-bold">{user?.name || 'Unknown'}</div>
                        <div class="text-sm opacity-50">{user?.email}</div>
                      </div>
                    </div>
                  </td>
                  <td class="font-bold text-error">${(payment.amount / 100).toFixed(2)}</td>
                  <td class="text-sm uppercase">{payment.currency}</td>
                  <td class="text-sm">{payment.description || 'N/A'}</td>
                  <td class="text-sm">{new Date(payment.createdAt).toLocaleDateString()}</td>
                  <td>
                    <div class="dropdown dropdown-end">
                      <label tabindex="0" class="btn btn-ghost btn-xs">
                        Actions
                      </label>
                      <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52">
                        <li>
                          <button class="text-info">
                            Retry Payment
                          </button>
                        </li>
                        <li>
                          <button class="text-warning">
                            Send Reminder
                          </button>
                        </li>
                        <li>
                          <button class="text-success">
                            Mark Resolved
                          </button>
                        </li>
                        <li>
                          <a href={`/admin/users/${user?.id}`}>View User</a>
                        </li>
                      </ul>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        
        {failedPayments.length === 0 && (
          <div class="p-8 text-center text-base-content/70">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-50 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <p>No failed payments</p>
            <p class="text-sm mt-2">All payments are processing successfully</p>
          </div>
        )}
      </div>

      <!-- Notes -->
      <div class="mt-6 bg-base-100 shadow rounded-lg p-6">
        <h3 class="font-semibold mb-4">💡 Dunning Best Practices</h3>
        <ul class="text-sm space-y-2 text-base-content/80">
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-info shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Retry payments after 3 days, then 7 days, then 14 days</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-info shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Send email reminders with link to update payment method</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-info shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Consider grace period of 7-14 days before downgrading</span>
          </li>
          <li class="flex items-start gap-2">
            <svg class="w-4 h-4 text-info shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>Track recovery rate to optimize dunning flow</span>
          </li>
        </ul>
      </div>
    </div>
  </main>
</Layout>
