---
/**
 * Admin Subscriptions Page
 * View and manage user subscriptions with status filtering.
 */
import AdminLayout from '../../../components/admin/AdminLayout.astro';
import DataTable from '../../../components/admin/DataTable.astro';
import { listSubscriptions } from '../../../lib/server/admin';

export const prerender = false;

// Admin auth is handled by AdminLayout
// Get subscriptions
const subscriptions = await listSubscriptions({ limit: 100 });

// Define table columns
const columns = [
  { 
    key: 'user', 
    label: 'User',
    render: (_: unknown, row: Record<string, unknown>) => {
      const user = row.user as { name?: string; email?: string } | null;
      const initial = user?.name?.charAt(0) || user?.email?.charAt(0)?.toUpperCase() || '?';
      return `
        <div class="flex items-center gap-3">
          <div class="avatar placeholder">
            <div class="bg-neutral text-neutral-content rounded-full w-10">
              <span class="text-sm">${initial}</span>
            </div>
          </div>
          <div>
            <div class="font-bold">${user?.name || 'Unknown'}</div>
            <div class="text-sm opacity-50">${user?.email || 'N/A'}</div>
          </div>
        </div>
      `;
    }
  },
  { 
    key: 'status', 
    label: 'Status', 
    sortable: true,
    render: (value: unknown) => {
      const status = String(value);
      const badgeClass = {
        'active': 'badge-success',
        'trialing': 'badge-info',
        'past_due': 'badge-warning',
        'canceled': 'badge-error',
      }[status] || 'badge-ghost';
      return `<span class="badge badge-sm ${badgeClass}">${status}</span>`;
    }
  },
  { 
    key: 'priceId', 
    label: 'Price ID',
    render: (value: unknown) => `<code class="text-xs">${value || 'N/A'}</code>`
  },
  { 
    key: 'currentPeriodEnd', 
    label: 'Period End', 
    sortable: true,
    render: (value: unknown) => {
      if (!value) return '<span class="text-base-content/50">N/A</span>';
      return new Date(value as string).toLocaleDateString();
    }
  },
  { 
    key: 'trialEnd', 
    label: 'Trial End',
    render: (value: unknown) => {
      if (!value) return '<span class="text-base-content/50">—</span>';
      return new Date(value as string).toLocaleDateString();
    }
  },
  { 
    key: 'cancelAtPeriodEnd', 
    label: 'Canceling',
    render: (value: unknown) => {
      if (value) {
        return '<span class="badge badge-warning badge-sm">Yes</span>';
      }
      return '<span class="text-base-content/50">No</span>';
    }
  },
  { 
    key: 'createdAt', 
    label: 'Created', 
    sortable: true,
    render: (value: unknown) => new Date(value as string).toLocaleDateString()
  }
];

// Flatten subscription data for table
const tableData = subscriptions.map(({ subscription, user }) => ({
  ...subscription,
  user
}));
---

<AdminLayout 
  title="Subscriptions" 
  description="View and manage user subscriptions"
  activeNav="subscriptions"
>
  <!-- Status Filter Pills -->
  <div class="mb-6 flex flex-wrap gap-2">
    <a href="/admin/subscriptions" class="btn btn-sm btn-ghost">All</a>
    <a href="/admin/subscriptions?status=active" class="btn btn-sm btn-ghost text-success">Active</a>
    <a href="/admin/subscriptions?status=trialing" class="btn btn-sm btn-ghost text-info">Trialing</a>
    <a href="/admin/subscriptions?status=past_due" class="btn btn-sm btn-ghost text-warning">Past Due</a>
    <a href="/admin/subscriptions?status=canceled" class="btn btn-sm btn-ghost text-error">Canceled</a>
  </div>

  <!-- Subscriptions Table -->
  <DataTable 
    columns={columns}
    data={tableData}
    searchable={true}
    searchPlaceholder="Search by user email or name..."
    emptyMessage="No subscriptions found"
  />

  <!-- Stats Summary -->
  <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
    <div class="stat bg-base-100 rounded-lg shadow">
      <div class="stat-title">Active</div>
      <div class="stat-value text-success text-2xl">
        {subscriptions.filter(s => s.subscription.status === 'active').length}
      </div>
    </div>
    <div class="stat bg-base-100 rounded-lg shadow">
      <div class="stat-title">Trialing</div>
      <div class="stat-value text-info text-2xl">
        {subscriptions.filter(s => s.subscription.status === 'trialing').length}
      </div>
    </div>
    <div class="stat bg-base-100 rounded-lg shadow">
      <div class="stat-title">Past Due</div>
      <div class="stat-value text-warning text-2xl">
        {subscriptions.filter(s => s.subscription.status === 'past_due').length}
      </div>
    </div>
    <div class="stat bg-base-100 rounded-lg shadow">
      <div class="stat-title">Canceled</div>
      <div class="stat-value text-error text-2xl">
        {subscriptions.filter(s => s.subscription.status === 'canceled').length}
      </div>
    </div>
  </div>
</AdminLayout>
