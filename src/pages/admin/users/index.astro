---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import { getSession, isAdmin } from '../../../lib/server/auth';
import { getCsrfToken } from '../../../lib/server/csrf';
import { listUsers } from '../../../lib/server/admin';

export const prerender = false;

// Check if user is authenticated
const authResult = await getSession(Astro);
const user = authResult?.user;

if (!user) {
  return Astro.redirect('/login?redirect=/admin/users');
}

// Check admin role
const userIsAdmin = await isAdmin(user.id);
if (!userIsAdmin) {
  return Astro.redirect('/dashboard?error=unauthorized');
}

// Get users
const users = await listUsers({ limit: 100 });
const csrfToken = getCsrfToken(Astro.cookies);
---

<Layout title="User Management - Admin Dashboard">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-8 px-4 sm:px-6 lg:px-8">
    <div class="max-w-7xl mx-auto">
      <!-- Header -->
      <div class="mb-8">
        <a href="/admin" class="btn btn-ghost btn-sm mb-4">
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to Dashboard
        </a>
        <h1 class="text-3xl font-bold">User Management</h1>
        <p class="text-base-content/70 mt-2">Manage user accounts and roles</p>
      </div>

      <!-- Filters -->
      <div class="bg-base-100 shadow rounded-lg p-4 mb-6">
        <div class="flex flex-wrap gap-4">
          <input 
            type="text" 
            placeholder="Search users..." 
            class="input input-bordered w-full max-w-xs"
            id="search-input"
          />
          <select class="select select-bordered" id="tier-filter">
            <option value="">All Tiers</option>
            <option value="free">Free</option>
            <option value="premium">Premium</option>
          </select>
          <select class="select select-bordered" id="status-filter">
            <option value="">All Status</option>
            <option value="active">Active</option>
            <option value="inactive">Inactive</option>
          </select>
        </div>
      </div>

      <!-- Users Table -->
      <div class="bg-base-100 shadow rounded-lg overflow-hidden">
        <div class="overflow-x-auto">
          <table class="table table-zebra w-full">
            <thead>
              <tr>
                <th>User</th>
                <th>Email</th>
                <th>Role</th>
                <th>Tier</th>
                <th>Status</th>
                <th>Joined</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="users-table-body">
              {users.map((u) => (
                <tr id={`user-row-${u.id}`}>
                  <td>
                    <div class="flex items-center gap-3">
                      <div class="avatar placeholder">
                        <div class="bg-neutral text-neutral-content rounded-full w-10">
                          <span class="text-sm">{u.name?.charAt(0) || u.email.charAt(0).toUpperCase()}</span>
                        </div>
                      </div>
                      <div>
                        <div class="font-bold">{u.name || 'No name'}</div>
                        <div class="text-sm opacity-50">@{u.username || 'no-username'}</div>
                      </div>
                    </div>
                  </td>
                  <td class="text-sm">{u.email}</td>
                  <td>
                    <span class={`badge badge-sm ${
                      u.role === 'admin' ? 'badge-error' :
                      u.role === 'moderator' ? 'badge-warning' :
                      'badge-ghost'
                    }`}>
                      {u.role}
                    </span>
                  </td>
                  <td>
                    <span class={`badge badge-sm ${
                      u.subscriptionTier === 'premium' ? 'badge-success' : 'badge-ghost'
                    }`}>
                      {u.subscriptionTier}
                    </span>
                  </td>
                  <td>
                    <span class={`badge badge-sm ${
                      u.isActive ? 'badge-success' : 'badge-error'
                    }`}>
                      {u.isActive ? 'Active' : 'Inactive'}
                    </span>
                  </td>
                  <td class="text-sm">{new Date(u.createdAt).toLocaleDateString()}</td>
                  <td>
                    <div class="dropdown dropdown-end">
                      <label tabindex="0" class="btn btn-ghost btn-xs">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v.01M12 12v.01M12 19v.01M12 6a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2zm0 7a1 1 0 110-2 1 1 0 010 2z" />
                        </svg>
                      </label>
                      <ul tabindex="0" class="dropdown-content menu p-2 shadow bg-base-100 rounded-box w-52">
                        <li><a href={`/admin/users/${u.id}`}>View Details</a></li>
                        {u.role !== 'admin' && (
                          <li>
                            <button 
                              class="text-warning"
                              hx-patch="/api/admin/users"
                              hx-headers={`{"Content-Type": "application/json"}`}
                              hx-post-params={`{"userId": ${u.id}, "action": "updateRole", "value": "admin", "csrfToken": "${csrfToken}"}`}
                              hx-confirm="Make this user an admin?"
                            >
                              Make Admin
                            </button>
                          </li>
                        )}
                        <li>
                          <button 
                            class={u.isActive ? 'text-error' : 'text-success'}
                            hx-patch="/api/admin/users"
                            hx-headers={`{"Content-Type": "application/json"}`}
                            hx-post-params={`{"userId": ${u.id}, "action": "setActive", "value": ${!u.isActive}, "csrfToken": "${csrfToken}"}`}
                            hx-confirm={u.isActive ? "Suspend this user?" : "Restore this user?"}
                          >
                            {u.isActive ? 'Suspend' : 'Restore'}
                          </button>
                        </li>
                      </ul>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        
        {users.length === 0 && (
          <div class="p-8 text-center text-base-content/70">
            <p>No users found</p>
          </div>
        )}
      </div>

      <!-- Pagination placeholder -->
      <div class="flex justify-center mt-6">
        <div class="btn-group">
          <button class="btn btn-sm" disabled>«</button>
          <button class="btn btn-sm btn-active">1</button>
          <button class="btn btn-sm" disabled>»</button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Client-side filtering
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-input');
    const tierFilter = document.getElementById('tier-filter');
    const statusFilter = document.getElementById('status-filter');
    const tableBody = document.getElementById('users-table-body');
    
    function filterUsers() {
      const search = searchInput?.value.toLowerCase() || '';
      const tier = tierFilter?.value || '';
      const status = statusFilter?.value || '';
      
      const rows = tableBody?.querySelectorAll('tr') || [];
      
      rows.forEach((row: HTMLTableRowElement) => {
        const text = row.textContent?.toLowerCase() || '';
        const tierBadge = row.querySelector('td:nth-child(4) .badge')?.textContent?.toLowerCase() || '';
        const statusBadge = row.querySelector('td:nth-child(5) .badge')?.textContent?.toLowerCase() || '';
        
        const matchesSearch = text.includes(search);
        const matchesTier = !tier || tierBadge.includes(tier);
        const matchesStatus = !status || statusBadge.includes(status);
        
        (row as HTMLElement).style.display = matchesSearch && matchesTier && matchesStatus ? '' : 'none';
      });
    }
    
    searchInput?.addEventListener('input', filterUsers);
    tierFilter?.addEventListener('change', filterUsers);
    statusFilter?.addEventListener('change', filterUsers);
  });
</script>
