---
import AuthLayout from '../../components/layout/AuthLayout.astro';
import Alert from '../../components/ui/Alert.astro';

import { getSession } from '../../lib/server/auth';

export const prerender = false;

// Check if user is authenticated
const authResult = await getSession(Astro, { requireAuth: true });
if (authResult instanceof Response) return authResult;
const { supabase } = authResult;

let error = '';
let success = false;

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const password = formData.get('password') as string;
  const confirmPassword = formData.get('confirm-password') as string;

  if (password !== confirmPassword) {
    error = 'Passwords do not match';
  } else if (password.length < 6) {
    error = 'Password must be at least 6 characters long';
  } else {
    try {
      const { error: updateError } = await supabase.auth.updateUser({
        password: password
      });

      if (updateError) {
        console.error('Password update error:', updateError);
        error = updateError.message;
      } else {
        success = true;
      }
    } catch (err) {
      console.error('Unexpected error:', err);
      error = 'An unexpected error occurred';
    }
  }
}
---

<AuthLayout 
  title="Update Password - YouTube Community Portal"
  heading="Update your password"
  subheading="Please enter your new password below."
>
  <Fragment slot="icon">
    <svg class="h-8 w-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
    </svg>
  </Fragment>

  <!-- Error Message -->
  {error && <Alert type="error" message={error} />}

  <!-- Success Message -->
  {success ? (
    <Alert type="success" message="Password updated successfully!">
      <div class="mt-4">
        <a href="/dashboard" class="text-sm font-medium text-primary hover:text-primary/80">
          Continue to Dashboard
        </a>
      </div>
    </Alert>
  ) : (
    <form class="mt-8 space-y-6" method="POST">
      <div class="space-y-4">
        <div>
          <label for="password" class="label">New Password</label>
          <input
            id="password"
            name="password"
            type="password"
            autocomplete="new-password"
            required
            class="input input-bordered w-full"
            placeholder="Enter new password"
            minlength="6"
          />
        </div>
        <div>
          <label for="confirm-password" class="label">Confirm New Password</label>
          <input
            id="confirm-password"
            name="confirm-password"
            type="password"
            autocomplete="new-password"
            required
            class="input input-bordered w-full"
            placeholder="Confirm new password"
            minlength="6"
          />
        </div>
      </div>

      <div>
        <button type="submit" class="btn btn-primary w-full">
          Update password
        </button>
      </div>
    </form>
  )}
</AuthLayout>