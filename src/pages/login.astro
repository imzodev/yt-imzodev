---
import AuthLayout from '../components/layout/AuthLayout.astro';
import Alert from '../components/ui/Alert.astro';
import { getSupabaseServerClient } from '../lib/supabase';
import { getCsrfToken, validateCsrfToken } from '../lib/server/csrf';
import { getSession } from '../lib/server/auth';

export const prerender = false;

// Check if user is already authenticated
const authResult = await getSession(Astro, { requireGuest: true });
if (authResult instanceof Response) return authResult;

let error = '';
let isInvalidCredentials = false;

// Handle form submission
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
  // Validate CSRF token
  const csrfToken = formData.get('csrf_token') as string | null;
  if (!validateCsrfToken(Astro.cookies, csrfToken)) {
    error = 'invalid_request';
  } else {
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    try {
      const supabase = getSupabaseServerClient(Astro.cookies);
      const { data, error: signInError } = await supabase.auth.signInWithPassword({
        email,
        password,
      });

      if (signInError) {
        console.error('Login error:', signInError);
        error = 'invalid_credentials';
        isInvalidCredentials = true;
      } else {
        // Redirect to dashboard on successful login
        return Astro.redirect('/dashboard');
      }
    } catch (err) {
      console.error('Unexpected error:', err);
      error = 'server_error';
    }
  }
} else {
  // Check URL params for errors/messages on GET
  error = Astro.url.searchParams.get('error') || '';
}

const showSuccessMessage = Astro.url.searchParams.get('message') === 'check_email';
---

<AuthLayout 
  title="Login - YouTube Community Portal"
  heading="Sign in to your account"
>
  <p slot="subheading-slot" class="mt-2 text-center text-sm text-base-content/70">
    Or{' '}
    <a href="/signup" class="font-medium text-primary hover:text-primary/80">
      create a new account
    </a>
  </p>

  <!-- Error Message -->
  {error && (
    <Alert type="error" message={
      error === 'invalid_credentials' || isInvalidCredentials
        ? 'Invalid email or password' 
        : error === 'invalid_request'
        ? 'Invalid request. Please try again.'
        : 'An error occurred during login'
    } />
  )}

  <!-- Success Message -->
  {showSuccessMessage && (
    <Alert type="success" message="Registration successful! Please check your email to verify your account." />
  )}

  <form class="mt-8 space-y-6" method="POST">
    <input type="hidden" name="csrf_token" value={getCsrfToken(Astro.cookies)} />
    <div class="space-y-4">
      <div>
        <label for="email" class="label">Email address</label>
        <input
          id="email"
          name="email"
          type="email"
          autocomplete="email"
          required
          class="input input-bordered w-full"
          placeholder="Enter your email"
        />
      </div>
      <div>
        <label for="password" class="label">Password</label>
        <input
          id="password"
          name="password"
          type="password"
          autocomplete="current-password"
          required
          class="input input-bordered w-full"
          placeholder="Enter your password"
        />
      </div>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex items-center">
        <input
          id="remember-me"
          name="remember-me"
          type="checkbox"
          class="h-4 w-4 text-primary focus:ring-primary border-base-300 rounded"
        />
        <label for="remember-me" class="ml-2 block text-sm text-base-content">
          Remember me
        </label>
      </div>

      <div class="text-sm">
        <a href="/forgot-password" class="font-medium text-primary hover:text-primary/80">
          Forgot your password?
        </a>
      </div>
    </div>

    <div>
      <button type="submit" class="btn btn-primary w-full">
        Sign in
      </button>
    </div>
  </form>

  <div class="mt-6">
    <div class="relative">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-base-300"></div>
        </div>
        <div class="relative flex justify-center text-sm">
          <span class="px-2 bg-base-200 text-base-content/60">Or continue with</span>
        </div>
      </div>

      <div class="mt-6 grid grid-cols-2 gap-3">
        <form method="POST" action="/api/auth/oauth" class="w-full">
          <input type="hidden" name="provider" value="google" />
          <button
            type="submit"
            class="w-full inline-flex justify-center py-2 px-4 border border-base-300 rounded-md shadow-sm bg-base-100 text-sm font-medium text-base-content hover:bg-base-200"
          >
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span class="ml-2">Google</span>
          </button>
        </form>

        <form method="POST" action="/api/auth/oauth" class="w-full">
          <input type="hidden" name="provider" value="github" />
          <button
            type="submit"
            class="w-full inline-flex justify-center py-2 px-4 border border-base-300 rounded-md shadow-sm bg-base-100 text-sm font-medium text-base-content hover:bg-base-200"
          >
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
            <span class="ml-2">GitHub</span>
          </button>
        </form>
      </div>
    </div>

</AuthLayout>
