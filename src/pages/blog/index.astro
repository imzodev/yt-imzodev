---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { supabase } from '../../lib/supabase';

// Fetch categories
const { data: categories } = await supabase
  .from('blog_categories')
  .select('*')
  .order('name');

// Get selected category
const selectedCategory = Astro.url.searchParams.get('category');

// Fetch posts
let query = supabase
  .from('blog_posts')
  .select(`
    *,
    category:blog_categories(name, slug),
    author:users(name, avatar)
  `)
  .eq('status', 'published')
  .order('published_at', { ascending: false });

if (selectedCategory) {
  query = query.eq('category:blog_categories.slug', selectedCategory);
}

const { data: posts, error } = await query;

const canonicalUrl = selectedCategory
  ? new URL(`/blog?category=${selectedCategory}`, Astro.url).href
  : new URL('/blog', Astro.url).href;

const pageDescription = selectedCategory
  ? `Browse ${selectedCategory} posts, tutorials, and creator updates from YouTube Community Portal.`
  : 'Browse blog posts, tutorials, and creator updates from YouTube Community Portal.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  name: 'YouTube Community Portal Blog',
  description: pageDescription,
  url: canonicalUrl,
};
---

<Layout
  title="Blog - YouTube Community Portal"
  description={pageDescription}
  canonical={canonicalUrl}
  type="website"
  jsonLd={jsonLd}
>
  <Navbar />
  <main class="min-h-screen bg-base-200 py-12 px-4 sm:px-6 lg:px-8 mt-16">
    <div class="max-w-7xl mx-auto space-y-8">
      
      <!-- Header -->
      <div class="text-center sm:text-left sm:flex sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-extrabold text-base-content sm:text-4xl">
            Blog
          </h1>
          <p class="mt-3 text-xl text-base-content/70">
            Thoughts, tutorials, and updates.
          </p>
        </div>
      </div>

      <!-- Categories Filter -->
      <div class="flex flex-wrap gap-2 pb-4 border-b border-base-300">
        <a 
          href="/blog" 
          class={`btn btn-sm ${!selectedCategory ? 'btn-primary' : 'btn-ghost border border-base-300'}`}
        >
          All
        </a>
        {categories?.map((cat) => (
          <a 
            href={`/blog?category=${cat.slug}`}
            class={`btn btn-sm ${selectedCategory === cat.slug ? 'btn-primary' : 'btn-ghost border border-base-300'}`}
          >
            {cat.name}
          </a>
        ))}
      </div>

      <!-- Posts Grid -->
      {error ? (
        <div class="alert alert-error">Failed to load blog posts.</div>
      ) : posts && posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post) => (
            <BlogCard post={post} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-base-100 rounded-lg shadow">
          <svg class="mx-auto h-12 w-12 text-base-content/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2 2 0 00-.586-1.414l-4.5-4.5A2 2 0 0012.586 3H12"></path>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-base-content">No posts</h3>
          <p class="mt-1 text-sm text-base-content/70">Check back later for new content.</p>
        </div>
      )}
    </div>
  </main>
</Layout>
