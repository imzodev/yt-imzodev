---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { supabase } from '../../lib/supabase';
import { Marked } from 'marked';
import { codeToHtml } from 'shiki';
import DOMPurify from 'dompurify';
import { JSDOM } from 'jsdom';
import { getEntry, render } from 'astro:content';

const { slug } = Astro.params;

// Fetch post details from Supabase for metadata (views, author, etc)
const { data: post, error } = await supabase
  .from('blog_posts')
  .select(`
    *,
    category:blog_categories(name, slug),
    author:users(name, avatar)
  `)
  .eq('slug', slug)
  .single();

if (error || !post || post.status !== 'published') {
  return Astro.redirect('/404');
}

// Try to get local MDX entry
const entry = await getEntry('blog', slug as string);
let Content;
if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

// Fallback: Convert markdown from DB to HTML securely with syntax highlighting
let contentHtml = '';
if (!Content) {
  try {
    const marked = new Marked({ async: true });
    
    marked.use({
      walkTokens: async (token) => {
        if (token.type === 'code') {
          try {
            const highlighted = await codeToHtml(token.text, {
              lang: token.lang || 'text',
              theme: 'github-dark'
            });
            
            token.type = 'html';
            token.text = `
              <div class="relative group bg-[#0d1117] rounded-xl overflow-hidden my-6 not-prose">
                <div class="absolute top-3 right-3 z-10 opacity-0 group-hover:opacity-100 transition-opacity">
                  <button 
                    class="copy-btn btn btn-sm btn-square btn-neutral border border-base-300 shadow-sm bg-base-100 text-base-content"
                    data-code="${token.text.replace(/"/g, '&quot;')}"
                    title="Copy code"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                    </svg>
                  </button>
                </div>
                <div class="overflow-x-auto text-sm p-4 custom-scrollbar shiki-container">
                  ${highlighted}
                </div>
              </div>
            `;
          } catch (e) {
            console.error("Failed to highlight code block", e);
          }
        }
      }
    });

    const rawHtml = await marked.parse(post.content || '');
    const window = new JSDOM('').window;
    const purify = DOMPurify(window);
    
    // Allow the custom HTML we added for the code blocks
    contentHtml = purify.sanitize(rawHtml, {
      ADD_TAGS: ['svg', 'path', 'button'],
      ADD_ATTR: ['stroke-linecap', 'stroke-linejoin', 'stroke-width', 'stroke', 'fill', 'viewBox', 'd', 'data-code']
    });
  } catch (e) {
    console.error("Error rendering markdown:", e);
    contentHtml = "<p>Error rendering content.</p>";
  }
}

// Format date
const formatDate = (dateString: string) => {
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric'
  }).format(date);
};
---

<Layout title={`${post.title} - YouTube Community Portal`}>
  <Navbar />
  <main class="min-h-screen bg-base-200 py-12 px-4 sm:px-6 lg:px-8 mt-16">
    <article class="max-w-5xl mx-auto space-y-8 bg-base-100 p-8 md:p-12 rounded-2xl shadow-xl">
      
      <!-- Breadcrumbs -->
      <div class="text-sm breadcrumbs text-base-content/70">
        <ul>
          <li><a href="/blog">Blog</a></li>
          {post.category && (
            <li><a href={`/blog?category=${post.category.slug}`}>{post.category.name}</a></li>
          )}
        </ul>
      </div>

      <!-- Header -->
      <header class="space-y-6">
        <h1 class="text-4xl md:text-5xl font-extrabold text-base-content leading-tight">
          {post.title}
        </h1>
        
        <div class="flex flex-wrap items-center justify-between gap-4 py-4 border-y border-base-200">
          <div class="flex items-center space-x-4">
            {post.author?.avatar ? (
              <div class="avatar">
                <div class="w-12 rounded-full">
                  <img src={post.author.avatar} alt={post.author.name} />
                </div>
              </div>
            ) : (
              <div class="avatar placeholder">
                <div class="bg-neutral text-neutral-content rounded-full w-12 text-xl">
                  <span>{post.author?.name?.charAt(0) || '?'}</span>
                </div>
              </div>
            )}
            <div>
              <p class="font-semibold text-base-content">{post.author?.name || 'Anonymous'}</p>
              <p class="text-sm text-base-content/60">{formatDate(post.published_at)}</p>
            </div>
          </div>

          <div class="flex items-center space-x-4 text-sm text-base-content/60">
            <span class="flex items-center">
              <svg class="w-5 h-5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
              {post.view_count || 0} views
            </span>
          </div>
        </div>
      </header>

      {post.featured_image && (
        <figure class="aspect-video w-full rounded-xl overflow-hidden">
          <img src={post.featured_image} alt={post.title} class="w-full h-full object-cover" />
        </figure>
      )}

      <!-- Content -->
      {Content ? (
        <div class="prose prose-lg md:prose-xl prose-base-content max-w-none prose-headings:font-bold prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-pre:bg-[#0d1117] prose-pre:border prose-pre:border-base-300">
          <Content />
        </div>
      ) : (
        <div 
          class="prose prose-lg md:prose-xl prose-base-content max-w-none prose-headings:font-bold prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-img:rounded-xl prose-pre:bg-[#0d1117] prose-pre:border prose-pre:border-base-300"
          set:html={contentHtml}
        />
      )}
      
      {post.tags && post.tags.length > 0 && (
        <div class="mt-12 pt-6 border-t border-base-200">
          <div class="flex flex-wrap gap-2">
            {post.tags.map((tag: string) => (
              <span class="badge badge-outline">{tag}</span>
            ))}
          </div>
        </div>
      )}
    </article>
  </main>
</Layout>

<script>
  // Copy to clipboard functionality
  document.addEventListener('click', async (e) => {
    const btn = (e.target as HTMLElement).closest('.copy-btn');
    if (!btn) return;
    
    const code = btn.getAttribute('data-code');
    if (!code) return;
    
    try {
      await navigator.clipboard.writeText(code);
      
      // Show success state
      const originalHtml = btn.innerHTML;
      btn.innerHTML = `
        <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      `;
      
      setTimeout(() => {
        btn.innerHTML = originalHtml;
      }, 2000);
    } catch (err) {
      console.error('Failed to copy text: ', err);
    }
  });
</script>

<style is:global>
  /* Customizing the Shiki output to fit nicely */
  .shiki-container pre {
    background-color: transparent !important;
    margin: 0;
    padding: 0;
  }
  .shiki-container code {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
    line-height: 1.5;
  }
  
  /* Custom scrollbar for the code block */
  .custom-scrollbar::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background-color: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background-color: rgba(255, 255, 255, 0.3);
  }
</style>
