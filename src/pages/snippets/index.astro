---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import SnippetCard from '../../components/snippet/SnippetCard.astro';
import { supabase } from '../../lib/supabase';

// Fetch categories
const { data: categories } = await supabase
  .from('snippet_categories')
  .select('*')
  .order('name');

// Get URL params
const selectedLanguage = Astro.url.searchParams.get('language');
const selectedCategory = Astro.url.searchParams.get('category');

// Fetch snippets
let query = supabase
  .from('snippets')
  .select(`
    *,
    category:snippet_categories(name, slug),
    author:users(name, avatar)
  `)
  .order('created_at', { ascending: false });

if (selectedLanguage) {
  query = query.eq('language', selectedLanguage);
}
if (selectedCategory) {
  query = query.eq('category:snippet_categories.slug', selectedCategory);
}

const { data: snippets, error } = await query;

// Extract unique languages for filter
const languages = snippets ? [...new Set(snippets.map(s => s.language))].filter(Boolean) : [];
---

<Layout title="Code Snippets - YouTube Community Portal">
  <Navbar />
  <main class="min-h-screen bg-base-200 py-12 px-4 sm:px-6 lg:px-8 mt-16">
    <div class="max-w-7xl mx-auto space-y-8">
      
      <!-- Header -->
      <div class="text-center sm:text-left sm:flex sm:items-center sm:justify-between">
        <div>
          <h1 class="text-3xl font-extrabold text-base-content sm:text-4xl">
            Code Snippets
          </h1>
          <p class="mt-3 text-xl text-base-content/70">
            A collection of useful components, hooks, and utilities.
          </p>
        </div>
      </div>

      <!-- Filters -->
      <div class="space-y-4 pb-4 border-b border-base-300">
        <!-- Language Filter -->
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-base-content/70 min-w-[80px]">Language:</span>
          <div class="flex flex-wrap gap-2">
            <a 
              href={`/snippets${selectedCategory ? `?category=${selectedCategory}` : ''}`} 
              class={`btn btn-xs ${!selectedLanguage ? 'btn-primary' : 'btn-ghost border border-base-300'}`}
            >
              All
            </a>
            {languages.map((lang) => (
              <a 
                href={`/snippets?language=${lang}${selectedCategory ? `&category=${selectedCategory}` : ''}`}
                class={`btn btn-xs ${selectedLanguage === lang ? 'btn-primary' : 'btn-ghost border border-base-300'}`}
              >
                {lang}
              </a>
            ))}
          </div>
        </div>

        <!-- Category Filter -->
        <div class="flex items-center gap-2">
          <span class="text-sm font-medium text-base-content/70 min-w-[80px]">Category:</span>
          <div class="flex flex-wrap gap-2">
            <a 
              href={`/snippets${selectedLanguage ? `?language=${selectedLanguage}` : ''}`} 
              class={`btn btn-xs ${!selectedCategory ? 'btn-secondary' : 'btn-ghost border border-base-300'}`}
            >
              All
            </a>
            {categories?.map((cat) => (
              <a 
                href={`/snippets?category=${cat.slug}${selectedLanguage ? `&language=${selectedLanguage}` : ''}`}
                class={`btn btn-xs ${selectedCategory === cat.slug ? 'btn-secondary' : 'btn-ghost border border-base-300'}`}
              >
                {cat.name}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Snippets Grid -->
      {error ? (
        <div class="alert alert-error">Failed to load snippets.</div>
      ) : snippets && snippets.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {snippets.map((snippet) => (
            <SnippetCard snippet={snippet} />
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-base-100 rounded-lg shadow">
          <svg class="mx-auto h-12 w-12 text-base-content/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          <h3 class="mt-2 text-sm font-medium text-base-content">No snippets found</h3>
          <p class="mt-1 text-sm text-base-content/70">Try adjusting your filters.</p>
        </div>
      )}
    </div>
  </main>
</Layout>
