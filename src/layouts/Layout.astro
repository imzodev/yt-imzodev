---
import "../styles/global.css";

export interface Props {
	title: string;
	description?: string;
	canonical?: string;
	image?: string;
	type?: 'website' | 'article';
	noindex?: boolean;
	jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title,
	description,
	canonical,
	image,
	type = 'website',
	noindex = false,
	jsonLd,
} = Astro.props;

const resolvedCanonical = canonical ?? Astro.url.href;
const resolvedDescription = description ?? 'YouTube Community Portal blog, tutorials, and creator updates.';
const resolvedImage = image ? new URL(image, Astro.url).href : undefined;
const jsonLdPayload = jsonLd ? JSON.stringify(jsonLd) : null;
---
<!doctype html>
<html lang="en">
	<head>
			<meta charset="UTF-8" />
			<meta name="viewport" content="width=device-width" />
			<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
			<link rel="icon" href="/favicon.ico" />
			
			<!-- Inter font from Google Fonts -->
			<link rel="preconnect" href="https://fonts.googleapis.com" />
			<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
			<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
			
			<meta name="generator" content={Astro.generator} />
			<title>{title}</title>
		<meta name="description" content={resolvedDescription} />
		<link rel="canonical" href={resolvedCanonical} />
		<meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

		<meta property="og:site_name" content="YouTube Community Portal" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={resolvedDescription} />
		<meta property="og:type" content={type} />
		<meta property="og:url" content={resolvedCanonical} />
		{resolvedImage && <meta property="og:image" content={resolvedImage} />}

		<meta name="twitter:card" content={resolvedImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={resolvedDescription} />
		{resolvedImage && <meta name="twitter:image" content={resolvedImage} />}

		{jsonLdPayload && (
			<script is:inline type="application/ld+json" set:html={jsonLdPayload} />
		)}
		<script is:inline>
			// Apply theme before page render to prevent FOUC
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			
			if (theme === 'light') {
				document.documentElement.setAttribute('data-theme', 'light');
			} else {
				document.documentElement.setAttribute('data-theme', 'dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body>
		<slot />
	</body>
</html>
