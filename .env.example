# Supabase Configuration
# Get these values from your Supabase project dashboard
# Go to Settings > API for URL and keys
# Go to Settings > Database > Connection String for DATABASE_URL

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database Configuration
# Use the connection string from Supabase Dashboard > Settings > Database
# Make sure to use connection pooling for better performance
# Format: postgresql://postgres.[project-ref]:[password]@[aws-region].pooler.supabase.com:6543/postgres

DATABASE_URL=postgresql://postgres.abc123:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Stripe Configuration
# Get these values from your Stripe dashboard
# Go to Developers > API Keys for the secret key

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Supabase Project ID (for generating types)
# Get this from your Supabase project settings
# REQUIRED for: bun run db:types

SUPABASE_PROJECT_ID=your-project-id

# Optional: Additional configuration
NODE_ENV=development
